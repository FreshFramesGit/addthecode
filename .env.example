# ═══ Monorepo env overview ═══════════════════════════════════
# Each workspace has its own .env.example:
#   astro-app/.env.example  — frontend vars (PUBLIC_* + server-side tokens)
#   studio/.env.example     — Studio vars (SANITY_STUDIO_*)
#
# Copy the workspace-specific files and fill in your project values:
#   cp astro-app/.env.example astro-app/.env
#   cp studio/.env.example studio/.env

# ─── Sanity project (shared reference) ──────────────────────
PUBLIC_SANITY_STUDIO_PROJECT_ID=your-project-id
PUBLIC_SANITY_STUDIO_DATASET=production
PUBLIC_SANITY_STUDIO_URL=http://localhost:3333
PUBLIC_SANITY_PROJECT_ID=your-project-id
PUBLIC_SANITY_DATASET=production

SANITY_STUDIO_PROJECT_ID=your-project-id
SANITY_STUDIO_DATASET=production
SANITY_STUDIO_PREVIEW_URL=http://localhost:4321
SANITY_STUDIO_STUDIO_HOST=your-studio.sanity.studio

# ─── Tokens (server-side only) ──────────────────────────────
SANITY_API_READ_TOKEN=your-viewer-token
# SANITY_API_WRITE_TOKEN=your-editor-token

# ─── Visual Editing ─────────────────────────────────────────
PUBLIC_SANITY_VISUAL_EDITING_ENABLED=false

# ─── Site URL contract ──────────────────────────────────────
# Use PUBLIC_SITE_URL as the canonical env name for the frontend.
# Astro derives import.meta.env.SITE from astro.config.mjs — do not set SITE manually in Vercel.
PUBLIC_SITE_URL=http://localhost:4321

# ─── Forms & bot protection (optional modules) ──────────────
PUBLIC_TURNSTILE_SITE_KEY=your-turnstile-site-key
TURNSTILE_SECRET_KEY=your-turnstile-secret-key
# CONTACT_WEBHOOK_URL=your-contact-webhook-or-esp-endpoint
# NEWSLETTER_WEBHOOK_URL=your-newsletter-webhook-or-esp-endpoint
