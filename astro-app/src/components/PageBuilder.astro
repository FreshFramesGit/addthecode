---
/**
 * PageBuilder — routes pageBuilder blocks to the correct section components.
 * Used by all pages that pull their content from the Sanity pageBuilder.
 *
 * Phase 2 (homepage): 9 blocks routeren naar echte components.
 * Phase 2.16: alle 26 Add the Code blocks routeren naar echte components.
 *
 * Universal Rule #4: respect `enabled` toggle — uitgeschakelde blocks worden
 * defensief gefilterd vóór render, naast de GROQ-side filter.
 */

// Add the Code — Hero's
import HeroHomeSection from './sections/HeroHomeSection.astro'
import HeroStandardSection from './sections/HeroStandardSection.astro'

// Add the Code — Sections
import PitchOpeningSection from './sections/PitchOpeningSection.astro'
import ServiceTriptychSection from './sections/ServiceTriptychSection.astro'
import QuoteClusterSection from './sections/QuoteClusterSection.astro'
import HeritageStripSection from './sections/HeritageStripSection.astro'
import ProjectGridSection from './sections/ProjectGridSection.astro'
import EssayGridSection from './sections/EssayGridSection.astro'
import TeamGridSection from './sections/TeamGridSection.astro'
import TimelineSection from './sections/TimelineSection.astro'
import PrinciplesSection from './sections/PrinciplesSection.astro'
import CtaRefreinSection from './sections/CtaRefreinSection.astro'

// Add the Code — Case-detail blocks
import DecisionsSection from './sections/DecisionsSection.astro'
import PhaseSection from './sections/PhaseSection.astro'
import MetaBlockSection from './sections/MetaBlockSection.astro'
import ArtifactGallerySection from './sections/ArtifactGallerySection.astro'
import MetricsStripSection from './sections/MetricsStripSection.astro'
import NextCaseSection from './sections/NextCaseSection.astro'
import NdaExplainerSection from './sections/NdaExplainerSection.astro'

// Add the Code — Forms + utility
import ContactFormSection from './sections/ContactFormSection.astro'
import NewsletterFormSection from './sections/NewsletterFormSection.astro'
import FaqSection from './sections/FaqSection.astro'
import DirectChannelsSection from './sections/DirectChannelsSection.astro'
import ExpectationStepsSection from './sections/ExpectationStepsSection.astro'
import CalloutSection from './sections/CalloutSection.astro'
import TagStripSection from './sections/TagStripSection.astro'
import PreClaimSection from './sections/PreClaimSection.astro'

// Legacy template-blocks (backwards-compat)
import HeroSection from './sections/HeroSection.astro'
import TextSection from './sections/TextSection.astro'
import ImageSection from './sections/ImageSection.astro'
import CtaSection from './sections/CtaSection.astro'
import ContactSection from './sections/ContactSection.astro'

interface Props {
  blocks: Array<{ _type: string; _key: string; enabled?: boolean; [key: string]: any }>
}

const { blocks } = Astro.props

/**
 * Component map: block._type → Astro component.
 *
 * Alle Add the Code blocks gemapt naar echte components per einde Phase 2.16.
 * Add new blocks: register in studio/src/schemaTypes/index.ts + page-builder.ts
 * accept-list, voeg PAGE_BUILDER_FRAGMENT branch toe in utils/sanity.ts,
 * import + map hier.
 */
const componentMap: Record<string, any> = {
  // ─── Add the Code Hero's ───
  heroHomeBlock: HeroHomeSection,
  heroStandardBlock: HeroStandardSection,

  // ─── Add the Code Sections ───
  pitchOpeningBlock: PitchOpeningSection,
  serviceTriptychBlock: ServiceTriptychSection,
  quoteClusterBlock: QuoteClusterSection,
  ctaRefreinBlock: CtaRefreinSection,
  heritageStripBlock: HeritageStripSection,
  projectGridBlock: ProjectGridSection,
  essayGridBlock: EssayGridSection,
  principlesBlock: PrinciplesSection,
  teamGridBlock: TeamGridSection,
  timelineBlock: TimelineSection,

  // ─── Add the Code Case-detail blocks ───
  decisionBlock: DecisionsSection,
  phaseBlock: PhaseSection,
  metaBlock: MetaBlockSection,
  artifactGalleryBlock: ArtifactGallerySection,
  metricsStripBlock: MetricsStripSection,
  nextCaseBlock: NextCaseSection,
  ndaExplainerBlock: NdaExplainerSection,

  // ─── Add the Code Forms + utility ───
  contactFormBlock: ContactFormSection,
  newsletterFormBlock: NewsletterFormSection,
  faqBlock: FaqSection,
  directChannelsBlock: DirectChannelsSection,
  expectationStepsBlock: ExpectationStepsSection,
  calloutBlock: CalloutSection,
  tagStripBlock: TagStripSection,
  preClaimBlock: PreClaimSection,

  // ─── Legacy template-blocks (backwards-compat) ───
  heroBlock: HeroSection,
  textBlock: TextSection,
  imageBlock: ImageSection,
  ctaBlock: CtaSection,
  contactBlock: ContactSection,
}

function resolveComponent(block: { _type: string; [key: string]: any }) {
  return componentMap[block._type] || null
}
---

{blocks?.filter((b) => b.enabled !== false)?.map((block) => {
  const Component = resolveComponent(block)
  if (!Component) {
    return import.meta.env.DEV
      ? <div class="page-builder__unknown" role="alert">
          <strong>Unknown block type:</strong> <code>{block._type}</code>
          <p class="page-builder__unknown-hint">
            Voeg block-type toe aan PageBuilder componentMap, of register
            in studio/src/schemaTypes/index.ts.
          </p>
        </div>
      : null
  }
  return <Component {...block} />
})}

<style>
  .page-builder__unknown {
    margin: var(--sp-4) 0;
    padding: var(--sp-5);
    background: rgba(217, 119, 87, 0.08);
    border: 2px solid var(--atc-claude);
    border-radius: var(--radius-main);
    color: var(--atc-ink);
    font-family: var(--font-mono);
    font-size: var(--fs-mono);
  }

  .page-builder__unknown code {
    background: var(--atc-paper);
    padding: 0 var(--sp-2);
    border-radius: var(--radius-small);
  }

  .page-builder__unknown-hint {
    margin-top: var(--sp-3);
    font-size: var(--fs-mono-small);
    color: var(--atc-ink-70);
  }
</style>
