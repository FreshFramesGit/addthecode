---
/**
 * SectionHeading — enterprise `.section-head` pattern.
 *
 * Layout (uit enterprise-redesign.css):
 *   <div class="section-head">
 *     <div class="section-head__intro">
 *       <svg class="tr"><circle class="tr__circle" /></svg>
 *       <span class="mono">{preClaim}</span>
 *     </div>
 *     <h2>{heading} <em>italic emphasis</em></h2>
 *     <p class="lead">{intro}</p>
 *   </div>
 *
 * Inline italic <em> voor mid-zin emphasis is een Add the Code conventie
 * (CtC-stijl). Editor markeert in heading-tekst met asterisks rond een
 * woordgroep: "We bouwen *systemen*, geen redesigns" → wij rendert die
 * woordgroep als <em>.
 */

interface Props {
  preClaim?: string | null
  heading?: string | null
  intro?: string | null
  level?: 1 | 2 | 3
  /** Op donkere zones */
  onDark?: boolean
  class?: string
}

const { preClaim, heading, intro, level = 2, onDark = false, class: className = '' } = Astro.props
const Heading = `h${level}` as 'h1' | 'h2' | 'h3'

const wrapperClass = ['section-head', className].filter(Boolean).join(' ')
const monoClass = `mono${onDark ? ' mono--on-dark' : ''}`
const leadClass = `lead${onDark ? ' lead--on-dark' : ''}`

/**
 * Parse asterisk-emphasis: "*woord*" → <em>woord</em>.
 * Conservatief: alleen bijschriften zonder nesting; geen markdown parser.
 */
function parseEmphasis(text: string): Array<{ type: 'text' | 'em'; value: string }> {
  const parts: Array<{ type: 'text' | 'em'; value: string }> = []
  const regex = /\*([^*]+)\*/g
  let lastIndex = 0
  let match
  while ((match = regex.exec(text)) !== null) {
    if (match.index > lastIndex) {
      parts.push({ type: 'text', value: text.slice(lastIndex, match.index) })
    }
    parts.push({ type: 'em', value: match[1] })
    lastIndex = regex.lastIndex
  }
  if (lastIndex < text.length) {
    parts.push({ type: 'text', value: text.slice(lastIndex) })
  }
  return parts.length ? parts : [{ type: 'text', value: text }]
}

const headingParts = heading ? parseEmphasis(heading) : []
---

<header class={wrapperClass}>
  {preClaim && (
    <div class="section-head__intro">
      <svg class="tr" viewBox="0 0 24 24" aria-hidden="true">
        <circle class="tr__circle" cx="12" cy="12" r="10" pathLength="70"></circle>
      </svg>
      <span class={monoClass}>{preClaim}</span>
    </div>
  )}
  {heading && (
    <Heading>
      {headingParts.map((p) =>
        p.type === 'em' ? <em>{p.value}</em> : <span>{p.value}</span>
      )}
    </Heading>
  )}
  {intro && <p class={leadClass}>{intro}</p>}
</header>
