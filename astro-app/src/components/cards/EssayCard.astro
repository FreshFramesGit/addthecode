---
/**
 * EssayCard — fcard pattern + flagship variant.
 *
 * Spec: docs/08 §3.3.
 * Variants:
 *  - standard → .fcard
 *  - flagship → eigen 60/40 split (groot)
 *  - compact  → kleine list-row
 */

import { urlFor } from '../../utils/sanity'
import CmsLink from '../content/CmsLink.astro'

interface Props {
  essay: any
  variant?: 'standard' | 'flagship' | 'compact' | null
}

const { essay, variant } = Astro.props

const safeVariant = variant ?? 'standard'
const slug = essay?.slug

const heroUrl = essay?.featuredImage?.asset?._id
  ? urlFor(essay.featuredImage).width(800).format('webp').url()
  : null

const date = essay?.publishedAt
  ? new Date(essay.publishedAt).toLocaleDateString('nl-NL', {
      year: 'numeric',
      month: 'long',
      day: 'numeric',
    })
  : null

const linkObject = { linkKind: 'internalPage', internalPage: { _type: 'essay', slug } }

const metaParts = [
  essay?.category ? essay.category.toUpperCase() : null,
  essay?.readTime,
  date,
].filter(Boolean)
---

{safeVariant === 'flagship' && (
  <article class="essay-flagship">
    <CmsLink link={linkObject} class="essay-flagship__link">
      {heroUrl && (
        <div class="essay-flagship__media">
          <img src={heroUrl} alt={essay?.featuredImage?.alt ?? essay?.title ?? ''} loading="lazy" />
        </div>
      )}
      <div class="essay-flagship__content">
        {metaParts.length > 0 && <span class="mono">{metaParts.join(' · ')}</span>}
        {essay?.title && <h3 class="essay-flagship__title">{essay.title}</h3>}
        {essay?.dek && <p class="lead">{essay.dek}</p>}
        {essay?.author?.name && <p class="mono">door {essay.author.name}</p>}
      </div>
    </CmsLink>
  </article>
)}

{safeVariant === 'standard' && (
  <article class="fcard">
    <CmsLink link={linkObject} style="display: contents; color: inherit; text-decoration: none;">
      <span class="fcard__num">{(essay?.category ?? 'ESSAY').toString().toUpperCase()}</span>
      {essay?.title && <h3 class="fcard__title">{essay.title}</h3>}
      {essay?.dek && <p class="fcard__pitch">{essay.dek}</p>}
      {essay?.readTime && <span class="fcard__tag">{essay.readTime}{date ? ` · ${date}` : ''}</span>}
    </CmsLink>
  </article>
)}

{safeVariant === 'compact' && (
  <article class="essay-compact">
    <CmsLink link={linkObject} class="essay-compact__link">
      <span class="mono" style="color: var(--atc-claude);">{(essay?.category ?? 'ESSAY').toString().toUpperCase()}</span>
      <span style="font-family: var(--font-display); font-size: 1.125rem; flex: 1;">{essay?.title}</span>
      {essay?.readTime && <span class="mono">{essay.readTime}</span>}
    </CmsLink>
  </article>
)}

<style>
  /* Flagship 60/40 */
  .essay-flagship {
    border: 1px solid var(--border-default);
    border-radius: var(--radius-main);
    overflow: hidden;
    background: var(--atc-paper);
    transition: border-color var(--dur-fast) var(--ease-out);
  }
  .essay-flagship:hover { border-color: var(--atc-mid-gray); }
  .essay-flagship__link {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0;
    color: inherit;
    text-decoration: none;
  }
  @media (max-width: 900px) { .essay-flagship__link { grid-template-columns: 1fr; } }
  .essay-flagship__media {
    aspect-ratio: 4 / 3;
    overflow: hidden;
    background: var(--bg-quiet);
  }
  .essay-flagship__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .essay-flagship__content {
    display: flex;
    flex-direction: column;
    gap: var(--sp-3);
    padding: var(--sp-6);
    align-self: center;
  }
  .essay-flagship__title {
    font-family: var(--font-display);
    font-style: italic;
    font-size: clamp(1.5rem, 1.5vw + 0.5rem, 2rem);
    line-height: 1.15;
    margin: 0;
  }

  /* Compact list-row */
  .essay-compact {
    border-bottom: 1px solid var(--border-default);
  }
  .essay-compact__link {
    display: flex;
    align-items: baseline;
    gap: var(--sp-4);
    padding: var(--sp-4) 0;
    color: inherit;
    text-decoration: none;
    transition: background var(--dur-fast) var(--ease-out);
  }
  .essay-compact__link:hover {
    text-decoration: none;
    background: var(--bg-quiet);
    padding-inline: var(--sp-3);
  }
</style>
