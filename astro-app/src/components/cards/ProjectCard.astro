---
/**
 * ProjectCard — case-card via enterprise patterns.
 *
 * Spec: docs/08 §3.2.
 * Variants:
 *  - featured-60-40 → image left + content right (custom hero-stijl card)
 *  - grid-3 / grid-2 → .fcard pattern (enterprise feature-card)
 *  - list           → simple horizontal row
 */

import { urlFor } from '../../utils/sanity'
import CmsLink from '../content/CmsLink.astro'

interface Props {
  case: any
  variant?: 'featured-60-40' | 'grid-2' | 'grid-3' | 'list' | null
}

const { case: caseDoc, variant } = Astro.props

const safeVariant = variant ?? 'grid-3'
const slug = caseDoc?.slug
const layer = caseDoc?.layer ?? 'launch'
const ndaStatus = caseDoc?.ndaStatus ?? false
const showClient = !(layer === 'in-flight' && ndaStatus)
const clientLabel = showClient ? caseDoc?.client : 'Onder NDA'

const heroUrl = caseDoc?.heroArtifact?.asset?._id
  ? urlFor(caseDoc.heroArtifact).width(1200).format('webp').url()
  : null

const period = caseDoc?.period
const periodLabel = period
  ? `${period.start?.slice(0, 7) ?? '?'} → ${period.isOngoing ? 'heden' : period.end?.slice(0, 7) ?? '?'}`
  : null

const linkObject = { linkKind: 'internalPage', internalPage: { _type: 'case', slug } }
---

{safeVariant === 'featured-60-40' && (
  <article class="project-featured">
    <CmsLink link={linkObject} class="project-featured__link">
      {heroUrl && (
        <div class={`project-featured__media ${ndaStatus ? 'project-featured__media--nda' : ''}`}>
          <img
            src={heroUrl}
            alt={caseDoc?.heroArtifact?.alt ?? caseDoc?.title ?? ''}
            loading="lazy"
          />
        </div>
      )}
      <div class="project-featured__content">
        {caseDoc?.preClaim && <span class="mono">{caseDoc.preClaim}</span>}
        {caseDoc?.title && <h3 class="project-featured__title">{caseDoc.title}</h3>}
        {caseDoc?.subtitle && <p class="lead">{caseDoc.subtitle}</p>}
        {caseDoc?.tags?.length > 0 && (
          <div class="project-featured__tags">
            {caseDoc.tags.slice(0, 4).map((tag: string) => <span class="chip">{tag}</span>)}
          </div>
        )}
        <span class="btn btn--ghost project-featured__cta">
          <span>Lees de case</span>
          <span class="btn__arrow" aria-hidden="true">→</span>
        </span>
      </div>
    </CmsLink>
  </article>
)}

{(safeVariant === 'grid-3' || safeVariant === 'grid-2') && (
  <article class={`fcard ${ndaStatus ? 'fcard--nda' : ''}`}>
    <CmsLink link={linkObject} style="display: contents; color: inherit; text-decoration: none;">
      {caseDoc?.preClaim && <span class="fcard__num">{caseDoc.preClaim}</span>}
      {caseDoc?.title && <h3 class="fcard__title">{caseDoc.title}</h3>}
      {caseDoc?.subtitle && <p class="fcard__pitch">{caseDoc.subtitle}</p>}
      {(clientLabel || periodLabel) && (
        <span class="fcard__tag">
          {clientLabel}{clientLabel && periodLabel && ' · '}{periodLabel}
        </span>
      )}
    </CmsLink>
  </article>
)}

{safeVariant === 'list' && (
  <article class="project-list-row">
    <CmsLink link={linkObject} class="project-list-row__link">
      <span class="mono" style="min-width: 8rem;">{periodLabel ?? '—'}</span>
      <span style="font-family: var(--font-display); font-size: 1.125rem; flex: 1;">
        {caseDoc?.title}
      </span>
      <span class="mono">{clientLabel ?? ''}</span>
      <span class="btn__arrow" aria-hidden="true">→</span>
    </CmsLink>
  </article>
)}

<style>
  /* ─── Featured 60/40 ──────────────────────────────────── */
  .project-featured {
    border: 1px solid var(--border-default);
    border-radius: var(--radius-main);
    overflow: hidden;
    background: var(--atc-paper);
    transition: border-color var(--dur-fast) var(--ease-out);
  }
  .project-featured:hover {
    border-color: var(--atc-mid-gray);
  }
  .project-featured__link {
    display: grid;
    grid-template-columns: 60% 40%;
    gap: 0;
    color: inherit;
    text-decoration: none;
  }
  @media (max-width: 900px) {
    .project-featured__link { grid-template-columns: 1fr; }
  }
  .project-featured__media {
    aspect-ratio: 4 / 3;
    overflow: hidden;
    background: var(--bg-quiet);
  }
  .project-featured__media--nda {
    filter: saturate(0.5) opacity(0.85);
  }
  .project-featured__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .project-featured__content {
    display: flex;
    flex-direction: column;
    gap: var(--sp-3);
    padding: var(--sp-6);
    align-self: center;
  }
  .project-featured__title {
    font-family: var(--font-display);
    font-style: italic;
    font-size: clamp(1.5rem, 1.5vw + 0.5rem, 2rem);
    line-height: 1.15;
    margin: 0;
  }
  .project-featured__tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--sp-2);
  }
  .project-featured__cta {
    align-self: flex-start;
    margin-top: var(--sp-3);
  }

  /* ─── List variant (heritage) ─────────────────────────── */
  .project-list-row {
    border-bottom: 1px solid var(--border-default);
  }
  .project-list-row__link {
    display: flex;
    align-items: center;
    gap: var(--sp-5);
    padding: var(--sp-4) 0;
    color: inherit;
    text-decoration: none;
    transition: background var(--dur-fast) var(--ease-out);
  }
  .project-list-row__link:hover {
    text-decoration: none;
    background: var(--bg-quiet);
    padding-inline: var(--sp-3);
  }
</style>
