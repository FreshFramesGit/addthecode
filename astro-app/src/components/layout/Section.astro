---
/**
 * Section — wrapper rond pageBuilder-blocks.
 *
 * Gebruikt enterprise-stijl classes uit `atc-components.css`:
 *   .section, .section--small, .section--large, .section--top, .section--ink
 *   .container, .container--wide, .container--narrow
 *
 * Tone-prop maps naar enterprise:
 *   paper  → standaard (geen modifier)
 *   ink    → .section--ink (donkere zone)
 *   claude → custom: oranje achtergrond (per docs/03 §2.3)
 */

interface Props {
  /** Tonale zone — paper (default), ink (donker), claude (oranje accent). */
  tone?: 'paper' | 'ink' | 'claude'
  /** Verticale padding-niveau. */
  padding?: 'none' | 'small' | 'main' | 'large' | 'page-top'
  /** Container-breedte: main (default), wide (88rem), narrow (essay), full (geen container). */
  container?: 'main' | 'wide' | 'narrow' | 'full'
  /** Hash-anchor ID. */
  anchorId?: string
  /** Optionele aria-label. */
  ariaLabel?: string
  /** Extra class voor component-specifieke styling. */
  class?: string
}

const {
  tone = 'paper',
  padding = 'main',
  container = 'main',
  anchorId,
  ariaLabel,
  class: className = '',
} = Astro.props

const sectionClasses = ['section']
if (padding === 'small') sectionClasses.push('section--small')
else if (padding === 'large') sectionClasses.push('section--large')
else if (padding === 'page-top') sectionClasses.push('section--top')
else if (padding === 'none') sectionClasses.push('section--none')

if (tone === 'ink') sectionClasses.push('section--ink')
else if (tone === 'claude') sectionClasses.push('section--claude')

// Tonale-zone helper-class voor child selectors via :global(.tone-*)
sectionClasses.push(`tone-${tone}`)

if (className) sectionClasses.push(className)

const containerClass =
  container === 'full'
    ? null
    : container === 'wide'
      ? 'container container--wide'
      : container === 'narrow'
        ? 'container container--narrow'
        : 'container'
---

<section
  class={sectionClasses.join(' ')}
  id={anchorId}
  aria-label={ariaLabel}
>
  {containerClass ? (
    <div class={containerClass}>
      <slot />
    </div>
  ) : (
    <slot />
  )}
</section>

<style>
  .section--none {
    padding-block: 0;
  }
  .section--claude {
    background: var(--atc-claude);
    color: var(--atc-ink);
  }
  .section--claude h1,
  .section--claude h2,
  .section--claude h3,
  .section--claude h4 {
    color: var(--atc-ink);
  }
</style>
