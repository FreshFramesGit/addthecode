---
/**
 * Nav — sitebreed sticky-top navigatie.
 *
 * Gebruikt enterprise-stijl classes (`.nav`, `.nav__inner`, `.nav__brand`,
 * `.nav__links`, `.nav__right`, `.nav__lang`, `.btn--primary`, `.tr`).
 * Layout 1:1 uit reference/design files/addthecode/enterprise.html.
 *
 * Sanity-driven:
 * - Navigation links komen uit `navigation.mainNav`
 * - CTA-button rechts trekt uit `componentDefaults.ctaRefreins[key=primary]`
 *
 * Mobile: hamburger drawer met init-guard tegen dubbele binding bij
 * View Transitions (Universal Rule #7).
 */
import { getNavigation, getSiteSettings, getComponentDefaults } from '../../utils/sanity'
import CmsLink from '../content/CmsLink.astro'

const [nav, settings, defaults] = await Promise.all([
  getNavigation(),
  getSiteSettings(),
  getComponentDefaults(),
])

const mainNav = nav?.mainNav ?? []
const siteName = settings?.siteName ?? 'Add the Code'

// CTA-button: pak primary refrein uit defaults
const ctaRefreins: any[] = defaults?.ctaRefreins ?? []
const primaryCta = ctaRefreins.find((c) => c.key === 'primary') ?? ctaRefreins[0] ?? null
const ctaLabel = primaryCta?.buttonLabel ?? null
const ctaLink = primaryCta?.buttonLink ?? null
---

<header class="nav nav-primary" aria-label="Hoofdnavigatie">
  <div class="nav__inner">
    {/* Brand: thinking ring + wordmark */}
    <a class="nav__brand" href="/" aria-label={`${siteName} — naar home`}>
      <svg class="tr" viewBox="0 0 24 24" aria-hidden="true">
        <circle class="tr__circle" cx="12" cy="12" r="10" pathLength="70"></circle>
      </svg>
      <b>{siteName}</b>
    </a>

    {/* Mobile hamburger */}
    <button
      type="button"
      class="nav__hamburger"
      aria-label="Menu openen"
      aria-expanded="false"
      aria-controls="nav-primary-menu"
      data-nav-toggle
    >
      <span class="nav__hamburger-bar"></span>
      <span class="nav__hamburger-bar"></span>
      <span class="nav__hamburger-bar"></span>
    </button>

    {/* Primary links */}
    <nav class="nav__links" id="nav-primary-menu" data-nav-menu aria-label="Primary">
      {mainNav.map((item: any) => {
        const hasChildren = item.children?.length > 0
        return (
          <CmsLink link={item.link} class={hasChildren ? 'has-caret' : ''}>
            {item.label}
          </CmsLink>
        )
      })}
    </nav>

    {/* Right side: CTA only (lang-toggle skipt v1 — NL-only) */}
    <div class="nav__right">
      {ctaLabel && ctaLink && (
        <CmsLink link={ctaLink} class="btn btn--primary">
          <svg class="tr" viewBox="0 0 24 24" aria-hidden="true">
            <circle class="tr__circle" cx="12" cy="12" r="10" pathLength="70"></circle>
          </svg>
          <span>{ctaLabel}</span>
          <span class="btn__arrow" aria-hidden="true">→</span>
        </CmsLink>
      )}
    </div>
  </div>
</header>

<script>
  function initNav() {
    const toggles = document.querySelectorAll<HTMLButtonElement>('[data-nav-toggle]')
    toggles.forEach((toggle) => {
      if (toggle.dataset.bound === 'true') return
      toggle.dataset.bound = 'true'
      toggle.addEventListener('click', () => {
        const menu = document.querySelector<HTMLElement>('[data-nav-menu]')
        if (!menu) return
        const isOpen = menu.classList.toggle('is-open')
        toggle.setAttribute('aria-expanded', String(isOpen))
        toggle.setAttribute('aria-label', isOpen ? 'Menu sluiten' : 'Menu openen')
        document.body.classList.toggle('is-nav-open', isOpen)
      })
    })
  }

  initNav()
  document.addEventListener('astro:page-load', initNav)
</script>

<style>
  /* Hamburger (mobile only) — overrides voor enterprise .nav */
  .nav__hamburger {
    display: none;
    flex-direction: column;
    gap: 4px;
    padding: var(--sp-3);
    background: transparent;
    border: 0;
    cursor: pointer;
  }
  .nav__hamburger-bar {
    display: block;
    width: 22px;
    height: 1.5px;
    background: var(--atc-ink);
    transition: transform var(--dur-fast), opacity var(--dur-fast);
  }

  @media (max-width: 767px) {
    .nav__hamburger {
      display: flex;
      order: 2;
    }
    .nav__links {
      position: fixed;
      top: 64px;
      left: 0;
      right: 0;
      bottom: 0;
      flex-direction: column;
      align-items: flex-start;
      gap: var(--sp-4);
      padding: var(--sp-6) var(--container-gutter);
      background: var(--atc-paper);
      transform: translateY(-110%);
      visibility: hidden;
      transition:
        transform var(--dur-normal) var(--ease-in-out),
        visibility 0s linear var(--dur-normal);
    }
    .nav__links.is-open {
      transform: translateY(0);
      visibility: visible;
      transition-delay: 0s;
    }
    .nav__links a {
      font-family: var(--font-display);
      font-size: var(--fs-h3);
    }
    .nav__right {
      display: none;
    }
    :global(body.is-nav-open) {
      overflow: hidden;
    }
  }
</style>
