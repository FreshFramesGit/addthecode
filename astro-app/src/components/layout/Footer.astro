---
/**
 * Footer — sitebreed.
 *
 * Gebruikt enterprise-stijl classes (`.footer`, `.footer__grid`,
 * `.footer__brand`, `.footer__col`, `.footer__legal`, `.newsletter`,
 * `.nav__brand`, `.tr`).
 *
 * Layout: 4-koloms grid (brand+address+newsletter / 3× nav).
 * Sanity-driven: footerNav komt uit navigation singleton, copy uit
 * componentDefaults.newsletter, brand-info uit siteSettings.
 */
import { getNavigation, getSiteSettings, getComponentDefaults } from '../../utils/sanity'
import CmsLink from '../content/CmsLink.astro'

const [nav, settings, defaults] = await Promise.all([
  getNavigation(),
  getSiteSettings(),
  getComponentDefaults(),
])

const footerNav = nav?.footerNav ?? []
const siteName = settings?.siteName ?? 'Add the Code'
const tagline = settings?.tagline ?? null
const studioAddress = settings?.studioAddress ?? null
const social = settings?.socialLinks ?? []
const newsletter = defaults?.newsletter ?? null

// Voor v1: alle footerNav-items in één kolom. Schema kan later kolom-veld toevoegen.
const footerNavItems = footerNav
---

<footer class="footer footer-primary" aria-label="Footer">
  <div class="container">
    <div class="footer__grid">
      {/* Brand kolom */}
      <div class="footer__brand">
        <a href="/" class="nav__brand" aria-label={`${siteName} — naar home`}>
          <svg class="tr" viewBox="0 0 24 24" aria-hidden="true">
            <circle class="tr__circle" cx="12" cy="12" r="10" pathLength="70"></circle>
          </svg>
          <b>{siteName}</b>
        </a>
        {tagline && <p class="footer__note">{tagline}</p>}

        {studioAddress && (
          <address class="footer__note" style="font-style: normal;">
            {studioAddress.addressLine1 && <div>{studioAddress.addressLine1}</div>}
            {(studioAddress.postalCode || studioAddress.city) && (
              <div>{studioAddress.postalCode} {studioAddress.city}</div>
            )}
            {studioAddress.openingHours && (
              <div class="mono" style="margin-top: var(--sp-2);">{studioAddress.openingHours}</div>
            )}
          </address>
        )}

        {newsletter && (
          <form
            class="newsletter"
            data-newsletter-form
            data-source="footer"
            novalidate
            style="margin-top: var(--sp-4);"
          >
            <label class="u-visually-hidden" for="footer-newsletter-email">
              Email-adres
            </label>
            <input
              type="email"
              id="footer-newsletter-email"
              name="email"
              required
              autocomplete="email"
              placeholder={newsletter.placeholder ?? ''}
            />
            <button type="submit" class="btn btn--primary">
              <span data-label-default>{newsletter.buttonLabel ?? 'Aanmelden'}</span>
              <span data-label-submitting hidden>
                {newsletter.buttonLabelSubmitting ?? newsletter.buttonLabel ?? 'Aanmelden'}
              </span>
            </button>
          </form>
        )}
        {newsletter?.helperLine && (
          <p class="mono" style="margin-top: var(--sp-2); font-size: var(--fs-meta);">
            {newsletter.helperLine}
          </p>
        )}
        <p
          class="footer__newsletter-feedback mono"
          data-newsletter-feedback
          aria-live="polite"
          hidden
          style="color: var(--atc-claude); margin-top: var(--sp-2);"
        ></p>
      </div>

      {/* Nav kolom — alle footerNav links */}
      {footerNavItems.length > 0 && (
        <div class="footer__col">
          <h5>Site</h5>
          <ul>
            {footerNavItems.map((item: any) => (
              <li>
                <CmsLink link={item.link}>{item.label}</CmsLink>
              </li>
            ))}
          </ul>
        </div>
      )}

      {/* Social kolom */}
      {social.length > 0 && (
        <div class="footer__col">
          <h5>Volg</h5>
          <ul>
            {social.map((s: any) => (
              <li>
                <a href={s.url} target="_blank" rel="noopener noreferrer">
                  {s.platform}
                </a>
              </li>
            ))}
          </ul>
        </div>
      )}

      {/* Contact kolom */}
      <div class="footer__col">
        <h5>Contact</h5>
        <ul>
          {settings?.email && (
            <li><a href={`mailto:${settings.email}`}>{settings.email}</a></li>
          )}
          {settings?.phone && (
            <li><a href={`tel:${settings.phone.replace(/\s+/g, '')}`}>{settings.phone}</a></li>
          )}
        </ul>
      </div>
    </div>

    {/* Legal regel onderaan */}
    <div class="footer__legal">
      <span>© {new Date().getFullYear()} {siteName}. Custom design, custom code.</span>
      <span>BTW · KVK informatie te vullen</span>
    </div>
  </div>
</footer>

<script>
  function initNewsletterForms() {
    const forms = document.querySelectorAll<HTMLFormElement>('[data-newsletter-form]')
    forms.forEach((form) => {
      if (form.dataset.bound === 'true') return
      form.dataset.bound = 'true'

      const submit = form.querySelector<HTMLButtonElement>('button[type="submit"]')
      const labelDefault = form.querySelector<HTMLElement>('[data-label-default]')
      const labelSubmitting = form.querySelector<HTMLElement>('[data-label-submitting]')
      const feedback = form.parentElement?.querySelector<HTMLElement>(
        '[data-newsletter-feedback]'
      )

      form.addEventListener('submit', async (e) => {
        e.preventDefault()
        const email = (form.querySelector<HTMLInputElement>('input[name="email"]')?.value ?? '').trim()
        const source = form.dataset.source ?? 'other'

        if (!email || !email.includes('@')) {
          if (feedback) {
            feedback.textContent = 'Vul een geldig email-adres in.'
            feedback.hidden = false
          }
          return
        }

        labelDefault?.setAttribute('hidden', '')
        labelSubmitting?.removeAttribute('hidden')
        submit?.setAttribute('disabled', '')

        try {
          const res = await fetch('/api/newsletter-subscribe', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ email, source }),
          })

          const result = (await res.json().catch(() => null)) as { ok?: boolean; error?: string } | null

          if (!res.ok || !result?.ok) {
            throw new Error(result?.error ?? `HTTP ${res.status}`)
          }

          if (feedback) {
            feedback.textContent =
              '◌ Ingeschreven. De volgende essay verschijnt binnen ±30 dagen in je inbox.'
            feedback.hidden = false
          }
          form.reset()
        } catch (err) {
          if (feedback) {
            const message = err instanceof Error ? err.message : ''
            feedback.textContent = message ||
              'Er ging iets mis. Probeer opnieuw of mail naar hello@addthecode.nl.'
            feedback.hidden = false
          }
        } finally {
          labelDefault?.removeAttribute('hidden')
          labelSubmitting?.setAttribute('hidden', '')
          submit?.removeAttribute('disabled')
        }
      })
    })
  }

  initNewsletterForms()
  document.addEventListener('astro:page-load', initNewsletterForms)
</script>
