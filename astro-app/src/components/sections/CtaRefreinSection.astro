---
/**
 * CtaRefreinSection — `.refrein` enterprise pattern (donker, watermark Ring).
 *
 * Spec: docs/09-microcopy §11.
 * Schema: ctaRefreinBlock.
 *
 * Defaults+override pattern via componentDefaults.ctaRefreins[key=pageKey].
 */

import Section from '../layout/Section.astro'
import CmsLink from '../content/CmsLink.astro'
import { getComponentDefaults } from '../../utils/sanity'

interface Props {
  enabled?: boolean
  pageKey?: string | null
  overrideStatement?: string | null
  overrideButtonLabel?: string | null
  overrideButtonLink?: any
  tone?: 'paper' | 'ink' | 'claude' | null
  anchorId?: string | null
}

const {
  pageKey,
  overrideStatement,
  overrideButtonLabel,
  overrideButtonLink,
  anchorId,
} = Astro.props

const safePageKey = pageKey ?? 'primary'

const defaults = await getComponentDefaults()
const ctaRefreins: any[] = defaults?.ctaRefreins ?? []
const matched = ctaRefreins.find((c) => c.key === safePageKey) ?? ctaRefreins[0] ?? null

const statement = overrideStatement ?? matched?.statement ?? null
const buttonLabel = overrideButtonLabel ?? matched?.buttonLabel ?? null
const buttonLink = overrideButtonLink ?? matched?.buttonLink ?? null
---

<Section padding="main" container="medium" anchorId={anchorId ?? undefined}>
  <div class="refrein">
    {statement && <h3>{statement}</h3>}

    {buttonLabel && buttonLink && (
      <CmsLink link={buttonLink} class="btn btn--on-dark">
        <svg class="tr" viewBox="0 0 24 24" aria-hidden="true">
          <circle class="tr__circle" cx="12" cy="12" r="10" pathLength="70"></circle>
        </svg>
        <span>{buttonLabel}</span>
        <span class="btn__arrow" aria-hidden="true">→</span>
      </CmsLink>
    )}

    {/* Watermark — grote stille Thinking Ring rechtsonder */}
    <div class="refrein__watermark" aria-hidden="true">
      <svg viewBox="0 0 100 100">
        <circle cx="50" cy="50" r="44" pathLength="68"
                fill="none" stroke="currentColor" stroke-width="1.2"
                stroke-dasharray="55 13" stroke-linecap="round"
                transform="rotate(20 50 50)" />
      </svg>
    </div>
  </div>
</Section>
