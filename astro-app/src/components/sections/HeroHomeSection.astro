---
/**
 * HeroHomeSection — Hero variant C 3-delig in enterprise styling.
 *
 * Spec: docs/07a §1 (3-delige merk-belofte: "Custom design. / Custom code. /
 * AI-versnelde bouw."), enterprise.html `.hero` pattern.
 *
 * Layout:
 *   .hero > .container--wide > .hero__grid
 *     LEFT col: .hero__meta (chips uit preClaim) + .hero__title (3 regels)
 *              + .hero__lede + .hero__ctas (.btn--primary + .btn--ghost)
 *     RIGHT col: optionele Thinking Ring xl (geen artefact-panel zoals
 *                enterprise — dat is enterprise-pagina specifiek)
 */

import CmsLink from '../content/CmsLink.astro'
import ThinkingRing from '../media/ThinkingRing.astro'

interface Cta {
  _key?: string
  label?: string | null
  variant?: 'primary' | 'secondary' | 'tertiary' | null
  link?: any
}

interface Props {
  enabled?: boolean
  preClaim?: string | null
  headlineParts?: string[] | null
  subClaim?: string | null
  bodyText?: string | null
  ctas?: Cta[] | null
  showThinkingRing?: boolean | null
  tone?: 'paper' | 'ink' | 'claude' | null
  anchorId?: string | null
}

const {
  preClaim,
  headlineParts,
  subClaim,
  bodyText,
  ctas,
  showThinkingRing,
  tone,
  anchorId,
} = Astro.props

const safeShowRing = showThinkingRing ?? true
const safeCtas = ctas ?? []
const parts = headlineParts ?? []

// Pre-claim → chips. Splits op " · " voor multi-chip rendering.
const chips = preClaim
  ? preClaim
      .replace(/^◌\s*/, '')
      .split('·')
      .map((s) => s.trim())
      .filter(Boolean)
  : []

// Variant → btn-class
function btnClass(variant: string | null | undefined): string {
  if (variant === 'secondary') return 'btn btn--ghost'
  if (variant === 'tertiary') return 'btn btn--ghost'
  return 'btn btn--primary'
}
---

<section
  class={`hero ${tone === 'ink' ? 'section--ink' : ''}`}
  id={anchorId ?? undefined}
  aria-label="Welkom bij Add the Code"
>
  <div class="container container--wide">
    <div class="hero__grid">
      <div>
        {chips.length > 0 && (
          <div class="hero__meta">
            {chips.map((c) => <span class="chip">◌ {c}</span>)}
          </div>
        )}

        {parts.length > 0 && (
          <h1 class="hero__title hero__title--stacked">
            {parts.map((part, i) => (
              <span class="hero__title-part">{part}</span>
            ))}
          </h1>
        )}

        {subClaim && <p class="hero__lede">{subClaim}</p>}

        {bodyText && <p class="hero__lede" style="margin-top: var(--sp-3);">{bodyText}</p>}

        {safeCtas.length > 0 && (
          <div class="hero__ctas">
            {safeCtas.map((cta) => (
              <CmsLink link={cta.link} class={btnClass(cta.variant)}>
                {cta.variant !== 'tertiary' && cta.variant !== 'secondary' && (
                  <svg class="tr" viewBox="0 0 24 24" aria-hidden="true">
                    <circle class="tr__circle" cx="12" cy="12" r="10" pathLength="70"></circle>
                  </svg>
                )}
                <span>{cta.label}</span>
                <span class="btn__arrow" aria-hidden="true">→</span>
              </CmsLink>
            ))}
          </div>
        )}
      </div>

      {safeShowRing && (
        <aside class="hero__artefact" aria-hidden="true">
          <div class="hero__artefact-label">
            <span>motif / ◌</span>
            <span>thinking-ring</span>
          </div>
          <div style="display: grid; place-items: center; min-height: 220px;">
            <ThinkingRing size="xl" tone="claude" motion="cycle" />
          </div>
          <div class="hero__artefact-foot">
            <span>SIGNATURE</span>
            <span>4S BREATH</span>
          </div>
        </aside>
      )}
    </div>
  </div>
</section>

<style>
  /* 3-delige headline: stacked layout (één regel per part) */
  .hero__title--stacked {
    display: flex;
    flex-direction: column;
    gap: 0;
  }
  .hero__title-part {
    display: block;
    font-style: italic;
  }
</style>
