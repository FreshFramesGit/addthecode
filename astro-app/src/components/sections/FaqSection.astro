---
/**
 * FaqSection — vraag-antwoord met optionele FAQPage JSON-LD voor SEO.
 *
 * Spec: docs/07j §5.
 * Schema: faqBlock.
 */

import Section from '../layout/Section.astro'
import SectionHeading from '../content/SectionHeading.astro'
import RichText from '../content/RichText.astro'

interface Item {
  _key?: string
  question?: string | null
  answer?: any
}

interface Props {
  enabled?: boolean
  preClaim?: string | null
  heading?: string | null
  items?: Item[] | null
  enableJsonLd?: boolean | null
  tone?: 'paper' | 'ink' | 'claude' | null
  anchorId?: string | null
}

const { preClaim, heading, items, enableJsonLd, tone, anchorId } = Astro.props

const safeTone = tone ?? 'paper'
const safeItems = items ?? []
const safeEnableJsonLd = enableJsonLd ?? false

// Helper: Portable Text → plain text voor JSON-LD
function portableTextToPlain(blocks: any[]): string {
  if (!Array.isArray(blocks)) return ''
  return blocks
    .filter((b) => b._type === 'block')
    .map((b) =>
      (b.children ?? [])
        .map((c: any) => c.text ?? '')
        .join('')
    )
    .join(' ')
}

const jsonLd =
  safeEnableJsonLd && safeItems.length > 0
    ? {
        '@context': 'https://schema.org',
        '@type': 'FAQPage',
        mainEntity: safeItems
          .filter((i) => i.question && i.answer)
          .map((i) => ({
            '@type': 'Question',
            name: i.question,
            acceptedAnswer: {
              '@type': 'Answer',
              text: portableTextToPlain(i.answer),
            },
          })),
      }
    : null
---

<Section
  tone={safeTone}
  padding="main"
  container="medium"
  anchorId={anchorId ?? undefined}
  class="faq"
>
  {(preClaim || heading) && (
    <SectionHeading
      preClaim={preClaim}
      heading={heading}
      level={2}
    />
  )}

  {safeItems.length > 0 && (
    <dl class="faq__list">
      {safeItems.map((item) => (
        <details class="faq__item">
          <summary class="faq__question">
            <span>{item.question}</span>
            <span class="faq__marker" aria-hidden="true">+</span>
          </summary>
          <div class="faq__answer">
            <RichText value={item.answer} />
          </div>
        </details>
      ))}
    </dl>
  )}
</Section>

{jsonLd && (
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
)}

<style>
  .faq__list {
    list-style: none;
    padding: 0;
    margin: var(--sp-5) 0 0;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .faq__item {
    border-top: 1px solid var(--border-default);
  }
  .faq__item:last-child {
    border-bottom: 1px solid var(--border-default);
  }
  :global(.tone-ink) .faq__item {
    border-color: var(--atc-paper-10);
  }

  .faq__question {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--sp-4);
    padding: var(--sp-4) 0;
    cursor: pointer;
    font-family: var(--font-display);
    font-style: italic;
    font-size: var(--fs-h4);
    color: var(--fg-primary);
    list-style: none;
  }
  .faq__question::-webkit-details-marker {
    display: none;
  }
  :global(.tone-ink) .faq__question {
    color: var(--fg-on-dark);
  }

  .faq__marker {
    flex-shrink: 0;
    font-family: var(--font-mono);
    font-size: var(--fs-h3);
    color: var(--atc-claude);
    transition: transform var(--dur-fast) var(--ease-out);
  }
  details[open] .faq__marker {
    transform: rotate(45deg);
  }

  .faq__answer {
    padding: 0 0 var(--sp-4);
    max-width: 60ch;
  }
  .faq__answer :global(p) {
    font-size: var(--fs-body);
    line-height: var(--lh-body);
    color: var(--fg-secondary);
    margin: 0 0 var(--sp-3);
  }
  :global(.tone-ink) .faq__answer :global(p) {
    color: var(--atc-paper-70);
  }
</style>
