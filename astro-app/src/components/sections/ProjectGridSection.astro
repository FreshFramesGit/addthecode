---
/**
 * ProjectGridSection — leest cases en rendert via enterprise grid.
 *
 * Spec: docs/07a §4 (featured op home), docs/07b (drielaag op /work).
 * Schema: projectGridBlock.
 *
 * Variants:
 *  - featured-60-40 → enkele case, hero-style card
 *  - grid-3 / grid-2 → fcard grid pattern
 *  - list → compacte horizontale rij
 */

import Section from '../layout/Section.astro'
import SectionHeading from '../content/SectionHeading.astro'
import ProjectCard from '../cards/ProjectCard.astro'
import { getCasesByLayer } from '../../utils/sanity'

interface Props {
  enabled?: boolean
  preClaim?: string | null
  heading?: string | null
  intro?: string | null
  layerFilter?: 'launch' | 'in-flight' | 'heritage' | 'featured' | 'all' | null
  maxItems?: number | null
  showFilterChips?: boolean | null
  cardLayoutVariant?: 'auto' | 'featured-60-40' | 'grid-2' | 'grid-3' | 'list' | null
  tone?: 'paper' | 'ink' | 'claude' | null
  anchorId?: string | null
}

const {
  preClaim,
  heading,
  intro,
  layerFilter,
  maxItems,
  cardLayoutVariant,
  tone,
  anchorId,
} = Astro.props

const safeTone = tone ?? 'paper'
const safeLayerFilter = (layerFilter ?? 'launch') as 'launch' | 'in-flight' | 'heritage' | 'all'
const queryLayer = (safeLayerFilter as any) === 'featured' ? 'all' : safeLayerFilter
const isOnDark = safeTone === 'ink'

const safeVariant =
  cardLayoutVariant === 'auto' || !cardLayoutVariant
    ? safeLayerFilter === 'launch'
      ? 'featured-60-40'
      : safeLayerFilter === 'in-flight'
        ? 'grid-2'
        : safeLayerFilter === 'heritage'
          ? 'list'
          : 'grid-3'
    : cardLayoutVariant

const cases = await getCasesByLayer(queryLayer)
const visibleCases = (maxItems ?? cases.length) > 0 ? cases.slice(0, maxItems ?? cases.length) : cases
---

<Section
  tone={safeTone}
  padding="main"
  container="main"
  anchorId={anchorId ?? undefined}
>
  {(preClaim || heading || intro) && (
    <SectionHeading preClaim={preClaim} heading={heading} intro={intro} level={2} onDark={isOnDark} />
  )}

  {visibleCases.length > 0 ? (
    <div class={`project-grid project-grid--${safeVariant}`}>
      {visibleCases.map((caseDoc: any) => (
        <ProjectCard case={caseDoc} variant={safeVariant} />
      ))}
    </div>
  ) : (
    <p class="lead">Nog geen cases in deze laag.</p>
  )}
</Section>

<style>
  .project-grid {
    margin-top: var(--sp-6);
  }
  .project-grid--featured-60-40 {
    display: block;
  }
  .project-grid--grid-3 {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--sp-5);
  }
  .project-grid--grid-2 {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--sp-5);
  }
  .project-grid--list {
    display: block;
  }
  @media (max-width: 991px) {
    .project-grid--grid-3 { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 600px) {
    .project-grid--grid-3,
    .project-grid--grid-2 { grid-template-columns: 1fr; }
  }
</style>
