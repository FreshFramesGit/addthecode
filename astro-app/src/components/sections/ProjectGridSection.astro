---
/**
 * ProjectGridSection — leest cases en rendert als grid/list per layer-filter.
 *
 * Spec: docs/07a §4 (featured op home), docs/07b (drielaag op /work).
 * Schema: projectGridBlock.
 *
 * Variants:
 *  - featured-60-40: enkele case, groot
 *  - grid-2 / grid-3: meerdere cards in grid
 *  - list: compacte heritage-lijst
 *  - auto: kies op basis van layerFilter (launch=featured-60-40, in-flight=grid-2, heritage=list)
 */

import Section from '../layout/Section.astro'
import SectionHeading from '../content/SectionHeading.astro'
import ProjectCard from '../cards/ProjectCard.astro'
import { getCasesByLayer } from '../../utils/sanity'

interface Props {
  enabled?: boolean
  preClaim?: string | null
  heading?: string | null
  intro?: string | null
  layerFilter?: 'launch' | 'in-flight' | 'heritage' | 'featured' | 'all' | null
  maxItems?: number | null
  showFilterChips?: boolean | null
  cardLayoutVariant?: 'auto' | 'featured-60-40' | 'grid-2' | 'grid-3' | 'list' | null
  tone?: 'paper' | 'ink' | 'claude' | null
  anchorId?: string | null
}

const {
  preClaim,
  heading,
  intro,
  layerFilter,
  maxItems,
  cardLayoutVariant,
  tone,
  anchorId,
} = Astro.props

const safeTone = tone ?? 'paper'
const safeLayerFilter = (layerFilter ?? 'launch') as 'launch' | 'in-flight' | 'heritage' | 'all'
// 'featured' is een UI-keuze maar geen aparte case-flag in v1 — voor nu gelijk aan 'all'
const queryLayer = safeLayerFilter === 'featured' as any ? 'all' : safeLayerFilter

// Resolve auto-variant op basis van layer
const safeVariant =
  cardLayoutVariant === 'auto' || !cardLayoutVariant
    ? safeLayerFilter === 'launch'
      ? 'featured-60-40'
      : safeLayerFilter === 'in-flight'
        ? 'grid-2'
        : safeLayerFilter === 'heritage'
          ? 'list'
          : 'grid-3'
    : cardLayoutVariant

const cases = await getCasesByLayer(queryLayer)
const visibleCases = (maxItems ?? cases.length) > 0 ? cases.slice(0, maxItems ?? cases.length) : cases

const gridClass = `project-grid__items project-grid__items--${safeVariant}`
---

<Section
  tone={safeTone}
  padding="main"
  container="main"
  anchorId={anchorId ?? undefined}
  class="project-grid"
>
  {(preClaim || heading || intro) && (
    <SectionHeading
      preClaim={preClaim}
      heading={heading}
      intro={intro}
      level={2}
    />
  )}

  {visibleCases.length > 0 ? (
    <div class={gridClass}>
      {visibleCases.map((caseDoc: any) => (
        <ProjectCard case={caseDoc} variant={safeVariant} />
      ))}
    </div>
  ) : (
    <p class="project-grid__empty">Nog geen cases in deze laag.</p>
  )}
</Section>

<style>
  .project-grid__items {
    display: grid;
    gap: var(--sp-5);
    margin-top: var(--sp-6);
  }

  .project-grid__items--featured-60-40 {
    grid-template-columns: 1fr;
  }

  .project-grid__items--grid-3 {
    grid-template-columns: repeat(3, 1fr);
  }

  .project-grid__items--grid-2 {
    grid-template-columns: repeat(2, 1fr);
  }

  .project-grid__items--list {
    grid-template-columns: 1fr;
    gap: 0;
  }

  .project-grid__empty {
    color: var(--fg-meta);
    font-size: var(--fs-body-small);
    margin-top: var(--sp-5);
  }

  @media (max-width: 991px) {
    .project-grid__items--grid-3 {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 479px) {
    .project-grid__items--grid-3,
    .project-grid__items--grid-2 {
      grid-template-columns: 1fr;
    }
  }
</style>
