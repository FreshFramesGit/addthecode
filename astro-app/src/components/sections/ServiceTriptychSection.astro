---
/**
 * ServiceTriptychSection — drie service-tiles in `.promise` enterprise pattern.
 *
 * Spec: docs/07a §3, enterprise.html `.promise` blok (Architect/Redesign/
 * Handover als referentie-instantie).
 *
 * Tile-mapping:
 *   tagline      → .promise__num    (mono Claude-orange, "01 · Design")
 *   title        → .promise__title  (FK Display met inline <em> emphasis)
 *   description  → .promise__pitch
 *   ctaLabel     → .promise__tag    (klikbaar als ctaLink aanwezig)
 *
 * Title kan asterisken bevatten voor emphasis: "We bouwen *systemen*, geen redesigns".
 */

import Section from '../layout/Section.astro'
import SectionHeading from '../content/SectionHeading.astro'
import CmsLink from '../content/CmsLink.astro'

interface Tile {
  _key?: string
  title?: string | null
  tagline?: string | null
  description?: string | null
  ctaLabel?: string | null
  ctaLink?: any
  icon?: string | null
}

interface Props {
  enabled?: boolean
  preClaim?: string | null
  heading?: string | null
  intro?: string | null
  tiles?: Tile[] | null
  tone?: 'paper' | 'ink' | 'claude' | null
  anchorId?: string | null
}

const { preClaim, heading, intro, tiles, tone, anchorId } = Astro.props

const safeTone = tone ?? 'paper'
const safeTiles = tiles ?? []

/** Parse asterisk-emphasis: "*woord*" → <em>woord</em> */
function parseEmphasis(text: string): Array<{ type: 'text' | 'em'; value: string }> {
  const parts: Array<{ type: 'text' | 'em'; value: string }> = []
  const regex = /\*([^*]+)\*/g
  let lastIndex = 0
  let match
  while ((match = regex.exec(text)) !== null) {
    if (match.index > lastIndex) parts.push({ type: 'text', value: text.slice(lastIndex, match.index) })
    parts.push({ type: 'em', value: match[1] })
    lastIndex = regex.lastIndex
  }
  if (lastIndex < text.length) parts.push({ type: 'text', value: text.slice(lastIndex) })
  return parts.length ? parts : [{ type: 'text', value: text }]
}
---

<Section
  tone={safeTone}
  padding="main"
  container="main"
  anchorId={anchorId ?? undefined}
>
  {(preClaim || heading || intro) && (
    <SectionHeading preClaim={preClaim} heading={heading} intro={intro} level={2} />
  )}

  {safeTiles.length > 0 && (
    <div class="promise">
      {safeTiles.map((tile, i) => {
        const num = tile.tagline ?? `0${i + 1}`
        const titleParts = tile.title ? parseEmphasis(tile.title) : []
        return (
          <article class="promise__item">
            <span class="promise__num">{num}</span>
            {tile.title && (
              <h3 class="promise__title">
                {titleParts.map((p) =>
                  p.type === 'em' ? <em>{p.value}</em> : <span>{p.value}</span>
                )}
              </h3>
            )}
            {tile.description && <p class="promise__pitch">{tile.description}</p>}
            {tile.ctaLabel && tile.ctaLink ? (
              <CmsLink link={tile.ctaLink} class="promise__tag promise__tag--link">
                {tile.ctaLabel} →
              </CmsLink>
            ) : tile.ctaLabel ? (
              <span class="promise__tag">{tile.ctaLabel}</span>
            ) : null}
          </article>
        )
      })}
    </div>
  )}
</Section>

<style>
  .promise__tag--link {
    color: var(--atc-signal);
    text-decoration: none;
    transition: color var(--dur-fast) var(--ease-out);
  }
  .promise__tag--link:hover {
    color: var(--atc-claude);
    text-decoration: none;
  }
</style>
