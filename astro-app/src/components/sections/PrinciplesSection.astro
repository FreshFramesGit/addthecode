---
/**
 * PrinciplesSection — genummerde principles-lijst.
 *
 * Spec: docs/07a §5, docs/07c team values pattern.
 * Schema: principlesBlock.
 *
 * Items genummerd op render-tijd (01, 02, ...).
 */

import Section from '../layout/Section.astro'
import SectionHeading from '../content/SectionHeading.astro'

interface Principle {
  _key?: string
  title?: string | null
  description?: string | null
}

interface Props {
  enabled?: boolean
  preClaim?: string | null
  heading?: string | null
  intro?: string | null
  principles?: Principle[] | null
  layoutVariant?: 'stack' | 'grid-2' | null
  tone?: 'paper' | 'ink' | 'claude' | null
  anchorId?: string | null
}

const { preClaim, heading, intro, principles, layoutVariant, tone, anchorId } = Astro.props

const safeTone = tone ?? 'paper'
const safeVariant = layoutVariant ?? 'stack'
const safePrinciples = principles ?? []
---

<Section
  tone={safeTone}
  padding="main"
  container="main"
  anchorId={anchorId ?? undefined}
  class="principles"
>
  {(preClaim || heading || intro) && (
    <SectionHeading
      preClaim={preClaim}
      heading={heading}
      intro={intro}
      level={2}
    />
  )}

  {safePrinciples.length > 0 && (
    <ol class={`principles__list principles__list--${safeVariant}`}>
      {safePrinciples.map((p, idx) => (
        <li class="principles__item">
          <span class="principles__number" aria-hidden="true">
            {String(idx + 1).padStart(2, '0')}
          </span>
          <div class="principles__content">
            <h3 class="principles__title">{p.title}</h3>
            <p class="principles__description">{p.description}</p>
          </div>
        </li>
      ))}
    </ol>
  )}
</Section>

<style>
  .principles__list {
    list-style: none;
    padding: 0;
    margin: var(--sp-6) 0 0;
    display: grid;
  }

  .principles__list--stack {
    grid-template-columns: 1fr;
    gap: var(--sp-5);
  }

  .principles__list--grid-2 {
    grid-template-columns: 1fr 1fr;
    gap: var(--sp-6);
  }

  .principles__item {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: var(--sp-4);
    padding-block: var(--sp-3);
    border-top: 1px solid var(--border-default);
  }
  :global(.tone-ink) .principles__item {
    border-top-color: var(--atc-paper-10);
  }

  .principles__number {
    font-family: var(--font-mono);
    font-size: var(--fs-mono-small);
    letter-spacing: var(--ls-mono-caps);
    color: var(--atc-claude);
    padding-top: 0.25em;
  }

  .principles__content {
    display: flex;
    flex-direction: column;
    gap: var(--sp-2);
  }

  .principles__title {
    font-family: var(--font-display);
    font-style: italic;
    font-size: var(--fs-h3);
    line-height: var(--lh-heading);
    margin: 0;
    text-wrap: balance;
  }

  .principles__description {
    font-size: var(--fs-body);
    line-height: var(--lh-body);
    color: var(--fg-secondary);
    margin: 0;
    text-wrap: pretty;
  }
  :global(.tone-ink) .principles__description {
    color: var(--atc-paper-70);
  }

  @media (max-width: 767px) {
    .principles__list--grid-2 {
      grid-template-columns: 1fr;
    }
  }
</style>
