---
/**
 * PrinciplesSection — `.benefits` enterprise grid pattern.
 *
 * Spec: docs/07a §5 + docs/03 §1 (vijf principes).
 * Schema: principlesBlock.
 *
 * Mapping:
 *   index+1     → .benefit__num   (mono Signal-blue, "01", "02")
 *   title       → .benefit__title (FK Display met inline <em> emphasis)
 *   description → .benefit__pitch
 */

import Section from '../layout/Section.astro'
import SectionHeading from '../content/SectionHeading.astro'

interface Principle {
  _key?: string
  title?: string | null
  description?: string | null
}

interface Props {
  enabled?: boolean
  preClaim?: string | null
  heading?: string | null
  intro?: string | null
  principles?: Principle[] | null
  layoutVariant?: 'stack' | 'grid-2' | null
  tone?: 'paper' | 'ink' | 'claude' | null
  anchorId?: string | null
}

const { preClaim, heading, intro, principles, layoutVariant, tone, anchorId } = Astro.props

const safeTone = tone ?? 'paper'
const safePrinciples = principles ?? []
const isOnDark = safeTone === 'ink'

function parseEmphasis(text: string) {
  const parts: Array<{ type: 'text' | 'em'; value: string }> = []
  const regex = /\*([^*]+)\*/g
  let lastIndex = 0
  let match
  while ((match = regex.exec(text)) !== null) {
    if (match.index > lastIndex) parts.push({ type: 'text', value: text.slice(lastIndex, match.index) })
    parts.push({ type: 'em', value: match[1] })
    lastIndex = regex.lastIndex
  }
  if (lastIndex < text.length) parts.push({ type: 'text', value: text.slice(lastIndex) })
  return parts.length ? parts : [{ type: 'text', value: text }]
}
---

<Section
  tone={safeTone}
  padding="main"
  container="main"
  anchorId={anchorId ?? undefined}
>
  {(preClaim || heading || intro) && (
    <SectionHeading preClaim={preClaim} heading={heading} intro={intro} level={2} onDark={isOnDark} />
  )}

  {safePrinciples.length > 0 && (
    <div class="benefits">
      {safePrinciples.map((p, i) => {
        const num = String(i + 1).padStart(2, '0')
        const titleParts = p.title ? parseEmphasis(p.title) : []
        return (
          <article class="benefit">
            <span class="benefit__num">{num}</span>
            {p.title && (
              <h3 class="benefit__title">
                {titleParts.map((part) =>
                  part.type === 'em' ? <em>{part.value}</em> : <span>{part.value}</span>
                )}
              </h3>
            )}
            {p.description && <p class="benefit__pitch">{p.description}</p>}
          </article>
        )
      })}
    </div>
  )}
</Section>
