---
/**
 * ExpectationStepsSection — drie-staps verwachting na contact.
 *
 * Spec: docs/07j §3.
 * Schema: expectationStepsBlock — defaults uit `componentDefaults.expectationSteps`,
 * override-velden in block hebben voorrang.
 */

import Section from '../layout/Section.astro'
import { getComponentDefaults } from '../../utils/sanity'

interface Step {
  _key?: string
  stepNumber?: string | null
  label?: string | null
  description?: string | null
}

interface Props {
  enabled?: boolean
  overrideHeading?: string | null
  overrideSteps?: Step[] | null
  tone?: 'paper' | 'ink' | 'claude' | null
  anchorId?: string | null
}

const { overrideHeading, overrideSteps, tone, anchorId } = Astro.props

const safeTone = tone ?? 'paper'

const defaults = await getComponentDefaults()
const expectations = defaults?.expectationSteps ?? null

const heading = overrideHeading ?? expectations?.heading ?? null
const steps =
  (overrideSteps && overrideSteps.length === 3 ? overrideSteps : expectations?.steps) ?? []
---

<Section
  tone={safeTone}
  padding="main"
  container="main"
  anchorId={anchorId ?? undefined}
  class="expectation-steps"
>
  {heading && <h3 class="expectation-steps__heading">{heading}</h3>}

  {steps.length > 0 && (
    <ol class="expectation-steps__list">
      {steps.map((step: Step) => (
        <li class="expectation-steps__item">
          <span class="expectation-steps__number" aria-hidden="true">
            {step.stepNumber}
          </span>
          <div class="expectation-steps__content">
            <h4 class="expectation-steps__label">{step.label}</h4>
            <p class="expectation-steps__description">{step.description}</p>
          </div>
        </li>
      ))}
    </ol>
  )}
</Section>

<style>
  .expectation-steps__heading {
    font-family: var(--font-display);
    font-style: italic;
    font-size: var(--fs-h2);
    margin: 0 0 var(--sp-5);
    text-wrap: balance;
  }

  .expectation-steps__list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--sp-5);
  }

  .expectation-steps__item {
    display: flex;
    flex-direction: column;
    gap: var(--sp-3);
    padding: var(--sp-5);
    border-top: 2px solid var(--atc-claude);
  }

  .expectation-steps__number {
    font-family: var(--font-mono);
    font-size: var(--fs-h3);
    color: var(--atc-claude);
    line-height: 1;
  }

  .expectation-steps__content {
    display: flex;
    flex-direction: column;
    gap: var(--sp-2);
  }

  .expectation-steps__label {
    font-family: var(--font-display);
    font-size: var(--fs-h4);
    margin: 0;
  }

  .expectation-steps__description {
    font-size: var(--fs-body-small);
    line-height: var(--lh-body);
    color: var(--fg-secondary);
    margin: 0;
  }
  :global(.tone-ink) .expectation-steps__description {
    color: var(--atc-paper-70);
  }

  @media (max-width: 767px) {
    .expectation-steps__list {
      grid-template-columns: 1fr;
    }
  }
</style>
