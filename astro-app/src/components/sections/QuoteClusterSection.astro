---
/**
 * QuoteClusterSection — `.quote` / `.quote--ink` enterprise pattern.
 *
 * Spec: docs/07a §6 + docs/08 §5.5.
 * Schema: quoteClusterBlock.
 *
 * Layout:
 *   - Primary quote (FK Display Italic, h2-size, op donkere achtergrond)
 *   - Optionele secundaire quotes (kleinere variant onder primary)
 *
 * Inline emphasis: render `*woord*` als <mark> (Claude underline) in primary.
 */

import Section from '../layout/Section.astro'
import SectionHeading from '../content/SectionHeading.astro'
import { urlFor } from '../../utils/sanity'

interface Quote {
  quote?: string | null
  name?: string | null
  role?: string | null
  company?: string | null
  portrait?: any
}

interface Props {
  enabled?: boolean
  preClaim?: string | null
  heading?: string | null
  primaryQuote?: Quote | null
  secondaryQuotes?: Quote[] | null
  tone?: 'paper' | 'ink' | 'claude' | null
  anchorId?: string | null
}

const { preClaim, heading, primaryQuote, secondaryQuotes, tone, anchorId } = Astro.props

const safeTone = tone ?? 'paper'
const safeSecondaries = secondaryQuotes ?? []
const isOnDark = safeTone === 'ink'

function attributionParts(q: Quote) {
  return [q.name ? { kind: 'name', value: q.name } : null, q.role, q.company]
    .filter(Boolean)
}

/** Markeer `*woord*` met <mark> (Claude-orange underline). */
function renderQuote(text: string) {
  const parts: Array<{ type: 'text' | 'mark'; value: string }> = []
  const regex = /\*([^*]+)\*/g
  let lastIndex = 0
  let match
  while ((match = regex.exec(text)) !== null) {
    if (match.index > lastIndex) parts.push({ type: 'text', value: text.slice(lastIndex, match.index) })
    parts.push({ type: 'mark', value: match[1] })
    lastIndex = regex.lastIndex
  }
  if (lastIndex < text.length) parts.push({ type: 'text', value: text.slice(lastIndex) })
  return parts.length ? parts : [{ type: 'text', value: text }]
}
---

<Section
  tone={safeTone}
  padding="small"
  container="medium"
  anchorId={anchorId ?? undefined}
>
  {(preClaim || heading) && (
    <SectionHeading preClaim={preClaim} heading={heading} level={2} onDark={isOnDark} />
  )}

  {primaryQuote && (
    <div class="quote quote--ink">
      <div class="quote__body">
        "{renderQuote(primaryQuote.quote ?? '').map((p) =>
          p.type === 'mark' ? <mark>{p.value}</mark> : <span>{p.value}</span>
        )}"
      </div>
      <div class="quote__attr">
        {primaryQuote.name && <span><b>{primaryQuote.name}</b></span>}
        {primaryQuote.role && <span>{primaryQuote.role}</span>}
        {primaryQuote.company && <span>{primaryQuote.company}</span>}
      </div>
    </div>
  )}

  {safeSecondaries.length > 0 && (
    <div class="quote-cluster__secondaries">
      {safeSecondaries.map((q) => (
        <div class="quote">
          <div class="quote__body" style="font-size: clamp(1.125rem, 1vw + 0.5rem, 1.375rem);">
            "{q.quote}"
          </div>
          <div class="quote__attr">
            {q.name && <span><b>{q.name}</b></span>}
            {q.role && <span>{q.role}</span>}
            {q.company && <span>{q.company}</span>}
          </div>
        </div>
      ))}
    </div>
  )}
</Section>

<style>
  .quote-cluster__secondaries {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--sp-5);
    margin-top: var(--sp-5);
  }
  @media (max-width: 767px) {
    .quote-cluster__secondaries {
      grid-template-columns: 1fr;
    }
  }
</style>
