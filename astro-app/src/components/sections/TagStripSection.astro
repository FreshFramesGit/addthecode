---
/**
 * TagStripSection — inline mono-tags strip als pageBuilder-element.
 *
 * Spec: docs/08 §5.2.
 * Schema: tagStripBlock.
 *
 * Voor stack-tags (services-pagina), case-tags inline, etc.
 */

import Section from '../layout/Section.astro'

interface Props {
  enabled?: boolean
  preClaim?: string | null
  tags?: string[] | null
  showAsLinks?: boolean | null
  tone?: 'paper' | 'ink' | 'claude' | null
  anchorId?: string | null
}

const { preClaim, tags, showAsLinks, tone, anchorId } = Astro.props

const safeTone = tone ?? 'paper'
const safeTags = tags ?? []
const linkable = showAsLinks ?? false
---

<Section
  tone={safeTone}
  padding="small"
  container="medium"
  anchorId={anchorId ?? undefined}
  class="tag-strip-section"
>
  {preClaim && <p class="tag-strip-section__pre">{preClaim}</p>}

  {safeTags.length > 0 && (
    <ul class="tag-strip-section__list" aria-label="Tags">
      {safeTags.map((tag) => (
        <li class="tag-strip-section__item">
          {linkable ? (
            <a href={`/work?tag=${encodeURIComponent(tag)}`} class="tag-strip-section__link">
              {tag}
            </a>
          ) : (
            <span>{tag}</span>
          )}
        </li>
      ))}
    </ul>
  )}
</Section>

<style>
  .tag-strip-section__pre {
    font-family: var(--font-mono);
    font-size: var(--fs-mono-small);
    letter-spacing: var(--ls-mono-caps);
    text-transform: uppercase;
    color: var(--fg-meta);
    margin: 0 0 var(--sp-3);
  }

  .tag-strip-section__list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    gap: var(--sp-2);
  }

  .tag-strip-section__item {
    font-family: var(--font-mono);
    font-size: var(--fs-mono-small);
    letter-spacing: var(--ls-mono-caps);
    text-transform: uppercase;
    color: var(--fg-meta);
    background: var(--bg-quiet);
    padding: var(--sp-1) var(--sp-3);
    border-radius: var(--radius-small);
  }
  :global(.tone-ink) .tag-strip-section__item {
    background: var(--atc-paper-10);
    color: var(--atc-paper-70);
  }

  .tag-strip-section__link {
    color: inherit;
    text-decoration: none;
    transition: color var(--dur-fast) var(--ease-out);
  }
  .tag-strip-section__link:hover {
    color: var(--atc-claude);
    text-decoration: none;
  }
</style>
