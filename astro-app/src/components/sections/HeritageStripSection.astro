---
/**
 * HeritageStripSection — chip-strip pattern.
 *
 * Spec: docs/08 §5.3.
 * Schema: heritageStripBlock.
 *
 * Items als horizontale chip-row, single line per item.
 */

import Section from '../layout/Section.astro'
import SectionHeading from '../content/SectionHeading.astro'

interface Props {
  enabled?: boolean
  preClaim?: string | null
  heading?: string | null
  items?: string[] | null
  tone?: 'paper' | 'ink' | 'claude' | null
  anchorId?: string | null
}

const { preClaim, heading, items, tone, anchorId } = Astro.props

const safeTone = tone ?? 'paper'
const safeItems = items ?? []
const isOnDark = safeTone === 'ink'
---

<Section
  tone={safeTone}
  padding="small"
  container="medium"
  anchorId={anchorId ?? undefined}
>
  {(preClaim || heading) && (
    <SectionHeading preClaim={preClaim} heading={heading} level={3} onDark={isOnDark} />
  )}

  {safeItems.length > 0 && (
    <div style="display: flex; flex-wrap: wrap; gap: var(--sp-3);">
      {safeItems.map((item) => (
        <span class={`chip ${isOnDark ? 'chip--on-dark' : ''}`}>{item}</span>
      ))}
    </div>
  )}
</Section>
