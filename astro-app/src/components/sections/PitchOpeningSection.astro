---
/**
 * PitchOpeningSection — vereenvoudigde pitch met enterprise typo.
 *
 * Spec: docs/07a §2 (home pitch), docs/07a §7 (approach-teaser-pattern).
 * Schema: pitchOpeningBlock.
 *
 * Enterprise-style: gebruikt .section-head + .lead. Optionele CTA als
 * .btn--ghost (tertiary-link met arrow).
 */

import Section from '../layout/Section.astro'
import SectionHeading from '../content/SectionHeading.astro'
import RichText from '../content/RichText.astro'
import CmsLink from '../content/CmsLink.astro'

interface Props {
  enabled?: boolean
  preClaim?: string | null
  heading?: string | null
  body?: any
  ctaLabel?: string | null
  ctaLink?: any
  maxWidth?: 'small' | 'main' | 'full' | null
  tone?: 'paper' | 'ink' | 'claude' | null
  anchorId?: string | null
}

const { preClaim, heading, body, ctaLabel, ctaLink, maxWidth, tone, anchorId } = Astro.props

const safeTone = tone ?? 'paper'
const containerSize = maxWidth === 'small' ? 'narrow' : maxWidth === 'full' ? 'full' : 'main'
const isOnDark = safeTone === 'ink'
const showCta = Boolean(ctaLabel && ctaLink)
---

<Section
  tone={safeTone}
  padding="main"
  container={containerSize}
  anchorId={anchorId ?? undefined}
>
  {(preClaim || heading) && (
    <SectionHeading preClaim={preClaim} heading={heading} level={2} onDark={isOnDark} />
  )}

  {body && (
    <div class={`lead ${isOnDark ? 'lead--on-dark' : ''}`} style="max-width: 56ch;">
      <RichText value={body} />
    </div>
  )}

  {showCta && (
    <p style="margin-top: var(--sp-5);">
      <CmsLink link={ctaLink} class="btn btn--ghost">
        <span>{ctaLabel}</span>
        <span class="btn__arrow" aria-hidden="true">→</span>
      </CmsLink>
    </p>
  )}
</Section>
