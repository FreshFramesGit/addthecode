---
/**
 * CtaSection — legacy template-block.
 *
 * NOTE: Add the Code sites gebruiken `CtaRefreinSection` met defaults+override
 * pattern. Dit component blijft voor backwards-compat (`ctaBlock` schema).
 *
 * Universal Rule #1: geen hardcoded visible strings. Render niets als Sanity
 * geen content levert — geen emergency-fallback meer.
 */
import Section from "../layout/Section.astro";
import CmsLink from "../content/CmsLink.astro";
import SanityImage from "../content/SanityImage.astro";
import { getComponentDefaults } from "../../utils/sanity";

interface Props {
  heading?: string | null;
  description?: string | null;
  contactName?: string | null;
  contactPhone?: string | null;
  contactEmail?: string | null;
  buttonLabel?: string | null;
  buttonLink?: any;
  backgroundStyle?: string | null;
  photo?: any;
  [key: string]: any;
}

const defaults = await getComponentDefaults(Astro.cookies);
const d = defaults?.cta;

// 2-layer fallback: props → componentDefaults. Geen hardcoded fallback (Rule #1).
const heading = Astro.props.heading ?? d?.heading ?? null;
const description = Astro.props.description ?? d?.description ?? null;
const contactName = Astro.props.contactName ?? d?.contactName ?? null;
const contactPhone = Astro.props.contactPhone ?? d?.contactPhone ?? null;
const contactEmail = Astro.props.contactEmail ?? d?.contactEmail ?? null;
const buttonLabel = Astro.props.buttonLabel ?? d?.buttonLabel ?? null;
const buttonLink = Astro.props.buttonLink ?? d?.buttonLink ?? null;
const photo = Astro.props.photo ?? d?.photo;
const backgroundStyle = Astro.props.backgroundStyle;

const hasContent = Boolean(heading || description || contactEmail || buttonLabel);
---

{hasContent && (
  <Section class={`cta-section ${backgroundStyle ? `bg-${backgroundStyle}` : ''}`}>
    <div class="cta_wrapper">
      <div class="cta_content">
        {heading && <h2>{heading}</h2>}
        {description && <p>{description}</p>}
        {contactName && <p class="cta_contact-name">{contactName}</p>}
        {contactPhone && <a href={`tel:${contactPhone}`}>{contactPhone}</a>}
        {contactEmail && <a href={`mailto:${contactEmail}`}>{contactEmail}</a>}
        {buttonLabel && buttonLink && (
          <CmsLink link={buttonLink} class="button">{buttonLabel}</CmsLink>
        )}
      </div>
      {photo?.asset && (
        <div class="cta_photo-wrapper">
          <SanityImage image={photo} width={400} class="cta_photo" />
        </div>
      )}
    </div>
  </Section>
)}
