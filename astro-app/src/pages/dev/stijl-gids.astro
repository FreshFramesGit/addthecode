            <p class="benefit__pitch">{b.pitch}</p>
          </article>
        ))}
      </div>
      <p class="mono" style="margin-top: var(--sp-3);">
        <code class="sg-code">.benefits &gt; .benefit &gt; .benefit__num + .benefit__title + .benefit__pitch</code>
      </p>

      <h3 class="sg-h3" style="margin-top: var(--sp-7);">Metrics (3-col, side-borders)</h3>
      <div class="metrics">
        {[
          { val: '3 mnd', desc: 'Enterprise platform live, inclusief data-migratie.', case: 'LAAG 01 · BELL' },
          { val: '4 000+', desc: 'CMS-items gemigreerd, drie talen, één bron.', case: 'LAAG 02 · NDA' },
          { val: '<em>5×</em> sneller', desc: 'Marketing ships updates — van ticket naar eigen-regie.', case: 'LAAG 03 · HERITAGE' },
        ].map((m) => (
          <div class="metric">
            <span class="metric__val" set:html={m.val}></span>
            <span class="metric__desc">{m.desc}</span>
            <span class="metric__case">{m.case}</span>
          </div>
        ))}
      </div>
      <p class="mono" style="margin-top: var(--sp-3);">
        <code class="sg-code">.metrics &gt; .metric &gt; .metric__val (em) + .metric__desc + .metric__case</code>
      </p>

      <h3 class="sg-h3" style="margin-top: var(--sp-7);">FCard (3-col feature card)</h3>
      <div class="fgrid">
        {[
          { num: '01', title: 'Modulair', pitch: 'Componenten die opnieuw te gebruiken zijn.', tag: 'Astro · Sanity' },
          { num: '02', title: 'Snel', pitch: 'Edge-rendered, statisch waar mogelijk.', tag: 'Vercel · CDN' },
          { num: '03', title: 'Eigen', pitch: 'Code in je eigen repo, geen vendor-lock.', tag: 'Open source' },
        ].map((f) => (
          <article class="fcard">
            <span class="fcard__num">{f.num}</span>
            <h3 class="fcard__title">{f.title}</h3>
            <p class="fcard__pitch">{f.pitch}</p>
            <span class="fcard__tag">{f.tag}</span>
          </article>
        ))}
      </div>
      <p class="mono" style="margin-top: var(--sp-3);">
        <code class="sg-code">.fgrid &gt; .fcard &gt; .fcard__num + .fcard__title + .fcard__pitch + .fcard__tag</code>
      </p>
    </div>
  </section>

  {/* ─── Quote ─── */}
  <section class="section" id="quote">
    <div class="container">
      <div class="section-head">
        <div class="section-head__intro">
          <svg class="tr" viewBox="0 0 24 24"><circle class="tr__circle" cx="12" cy="12" r="10" pathLength="70"/></svg>
          <span class="mono">§ 09 · Quote</span>
        </div>
        <h2>Twee varianten: <em>plain</em> en <em>ink</em> (donker).</h2>
      </div>

      <h3 class="sg-h3">Plain quote</h3>
      <div class="quote">
        <div class="quote__body">
          "Sample quote — Italic FK Display, max-width 56ch, line-height 1.3."
        </div>
        <div class="quote__attr">
          <span><b>Sample Naam</b></span>
          <span>Functie, Bedrijf</span>
          <span>LAAG 03 · HERITAGE</span>
        </div>
      </div>

      <h3 class="sg-h3" style="margin-top: var(--sp-7);">Ink quote (met &lt;mark&gt; emphasis)</h3>
      <div class="quote quote--ink">
        <div class="quote__body">
          "Je kunt ze écht vertrouwen met complex werk — ze zijn <mark>top-notch in hun vak</mark> en we kunnen ze alleen maar aanbevelen."
        </div>
        <div class="quote__attr">
          <span><b>Arnaud Barbezat</b></span>
          <span>Int'l Marketing Manager</span>
          <span>LAAG 03 · HERITAGE</span>
        </div>
      </div>
      <p class="mono" style="margin-top: var(--sp-3);">
        <code class="sg-code">.quote</code> · <code class="sg-code">.quote--ink</code> + <code class="sg-code">&lt;mark&gt;</code> = Claude underline
      </p>
    </div>
  </section>

  {/* ─── Refrein ─── */}
  <section class="section" id="refrein">
    <div class="container">
      <div class="section-head">
        <div class="section-head__intro">
          <svg class="tr" viewBox="0 0 24 24"><circle class="tr__circle" cx="12" cy="12" r="10" pathLength="70"/></svg>
          <span class="mono">§ 10 · Refrein</span>
        </div>
        <h2>Sitebreed CTA-blok <em>met watermark Ring</em>.</h2>
      </div>

      <div class="refrein">
        <h3>Klaar om weer met eigen code te bouwen?</h3>
        <a class="btn btn--on-dark" href="#">
          <svg class="tr" viewBox="0 0 24 24"><circle class="tr__circle" cx="12" cy="12" r="10" pathLength="70"/></svg>
          <span>Plan een gesprek</span>
          <span class="btn__arrow">→</span>
        </a>
        <div class="refrein__watermark" aria-hidden="true">
          <svg viewBox="0 0 100 100">
            <circle cx="50" cy="50" r="44" pathLength="68"
                    fill="none" stroke="currentColor" stroke-width="1.2"
                    stroke-dasharray="55 13" stroke-linecap="round"
                    transform="rotate(20 50 50)" />
          </svg>
        </div>
      </div>
      <p class="mono" style="margin-top: var(--sp-3);">
        <code class="sg-code">.refrein &gt; h3 + .btn--on-dark + .refrein__watermark</code>
      </p>
    </div>
  </section>

  {/* ─── Newsletter ─── */}
  <section class="section" id="newsletter">
    <div class="container">
      <div class="section-head">
        <div class="section-head__intro">
          <svg class="tr" viewBox="0 0 24 24"><circle class="tr__circle" cx="12" cy="12" r="10" pathLength="70"/></svg>
          <span class="mono">§ 11 · Newsletter form</span>
        </div>
        <h2>Compact email-subscribe pattern <em>met focus state</em>.</h2>
      </div>

      <form class="newsletter" onsubmit="event.preventDefault();" novalidate>
        <input type="email" placeholder="jij@bedrijf.nl" />
        <button type="submit" class="btn btn--primary">
          <span>Aanmelden</span>
          <span class="btn__arrow">→</span>
        </button>
      </form>
      <p class="mono" style="margin-top: var(--sp-3);">
        <code class="sg-code">.newsletter &gt; input + .btn--primary</code>
      </p>
    </div>
  </section>

  {/* ─── Thinking Ring ─── */}
  <section class="section" id="thinking-ring">
    <div class="container">
      <div class="section-head">
        <div class="section-head__intro">
          <svg class="tr" viewBox="0 0 24 24"><circle class="tr__circle" cx="12" cy="12" r="10" pathLength="70"/></svg>
          <span class="mono">§ 12 · Thinking Ring</span>
        </div>
        <h2>Signature motif — <em>5 maten, 4 motion-modes</em>.</h2>
      </div>

      <h3 class="sg-h3">Maten</h3>
      <div class="sg-rings">
        {(['xs', 'sm', 'md', 'lg', 'xl'] as const).map((size) => (
          <div class="sg-ring-cell">
            <ThinkingRing size={size} tone="claude" motion="cycle" />
            <code>{size}</code>
          </div>
        ))}
      </div>

      <h3 class="sg-h3" style="margin-top: var(--sp-7);">Motion modes</h3>
      <div class="sg-rings">
        <div class="sg-ring-cell">
          <ThinkingRing size="md" tone="claude" motion="cycle" />
          <code>cycle (default)</code>
        </div>
        <div class="sg-ring-cell">
          <ThinkingRing size="md" tone="claude" motion="static" />
          <code>static (canoniek 80%)</code>
        </div>
        <div class="sg-ring-cell">
          <a href="#" class="has-ring-hover" style="display:grid; place-items:center; gap:var(--sp-2); text-decoration:none; color:inherit;">
            <ThinkingRing size="md" tone="claude" motion="hover-rotate" />
            <code>hover-rotate (hover hier)</code>
          </a>
        </div>
      </div>

      <h3 class="sg-h3" style="margin-top: var(--sp-7);">Tones</h3>
      <div class="sg-rings">
        <div class="sg-ring-cell">
          <ThinkingRing size="md" tone="claude" motion="cycle" />
          <code>claude (default)</code>
        </div>
        <div class="sg-ring-cell">
          <ThinkingRing size="md" tone="ink" motion="cycle" />
          <code>ink</code>
        </div>
        <div class="sg-ring-cell" style="background: var(--atc-ink); padding: var(--sp-3); border-radius: var(--radius-main);">
          <ThinkingRing size="md" tone="paper" motion="cycle" />
          <code style="color: var(--atc-paper);">paper (op donker)</code>
        </div>
      </div>

      <h3 class="sg-h3" style="margin-top: var(--sp-7);">Inline (in tekst)</h3>
      <p style="font-size: var(--fs-h3); font-family: var(--font-display); margin: 0;">
        Een zin met <ThinkingRing size="inline" tone="claude" motion="cycle" /> ring inline.
      </p>
      <p class="mono" style="margin-top: var(--sp-2);">
        <code class="sg-code">&lt;ThinkingRing size="inline" tone="claude" motion="cycle" /&gt;</code>
      </p>
    </div>
  </section>
</Layout>

<style>
  /* ─── Style guide eigen styling ──────────────────────────── */

  .sg-toc {
