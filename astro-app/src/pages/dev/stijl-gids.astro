  .sg-pad-demo--ink {
    background: var(--atc-ink);
    border-color: var(--atc-spark);
  }

  /* ─── Thinking Ring grid ────────────────────────────────── */
  .sg-rings {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(10rem, 1fr));
    gap: var(--sp-5);
    align-items: end;
  }
  .sg-ring-cell {
    display: grid;
