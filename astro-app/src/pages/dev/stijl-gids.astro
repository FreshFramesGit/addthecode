      repeating-linear-gradient(
        45deg,
        rgba(251, 202, 16, 0.08) 0,
        rgba(251, 202, 16, 0.08) 8px,
        transparent 8px,
        transparent 16px
      );
  }

  /* Container demos — toont label + empty-box per maat */
  .sg-container-demo,
