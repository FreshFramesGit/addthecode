    color: var(--atc-ink);
  }

  .sg-stack {
    display: flex;
    flex-direction: column;
    gap: var(--sp-4);
  }

  .sg-row {
    display: flex;
    flex-wrap: wrap;
    gap: var(--sp-3);
    align-items: center;
  }

  .sg-list {
    list-style: none;
    padding: 0;
    margin: 0;
