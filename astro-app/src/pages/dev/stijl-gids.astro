          </article>
        ))}
      </div>
      <p class="mono" style="margin-top: var(--sp-3);">
        <code class="sg-code">.promise &gt; .promise__item &gt; .promise__num + .promise__title (em) + .promise__pitch + .promise__tag</code>
      </p>

      <h3 class="sg-h3" style="margin-top: var(--sp-7);">Benefits (3-col, top-border)</h3>
      <div class="benefits">
        {[
          { num: '01', title: 'Schaalt met je groei', pitch: 'Geen plugin-onderhoud, geen rebuild bij elke groeisprong.' },
          { num: '02', title: 'Opnieuw of migreren', pitch: 'From-scratch of migratie, zonder downtime, zonder SEO-verlies.' },
          { num: '03', title: 'In-house launchen', pitch: 'Je team maakt branded pages — uren, niet weken.' },
        ].map((b) => (
          <article class="benefit">
            <span class="benefit__num">{b.num}</span>
