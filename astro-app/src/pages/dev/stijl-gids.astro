    flex-direction: column;
    gap: 4px;
    font-size: var(--fs-body-small);
  }
  .sg-swatch__meta strong {
    font-weight: 500;
  }
  .sg-swatch__meta code {
    font-family: var(--font-mono);
    font-size: var(--fs-mono-small);
    color: var(--fg-meta);
  }
  .sg-swatch--semantic {
    padding: var(--sp-3);
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  /* ─── Spacing rows ──────────────────────────────────────── */
  .sg-spacing {
    display: flex;
    flex-direction: column;
    gap: var(--sp-2);
  }
  .sg-spacing__row {
    display: grid;
    grid-template-columns: 8rem 1fr 4rem;
    gap: var(--sp-3);
    align-items: center;
    padding: var(--sp-2) 0;
    border-bottom: 1px solid var(--border-default);
  }
  .sg-spacing__token {
    font-family: var(--font-mono);
    font-size: var(--fs-mono-small);
    color: var(--atc-claude);
  }
  .sg-spacing__bar {
    display: inline-block;
    height: 8px;
    background: var(--atc-claude);
    border-radius: var(--radius-small);
  }
  .sg-spacing__val {
    font-family: var(--font-mono);
    font-size: var(--fs-mono-small);
    color: var(--fg-meta);
    text-align: right;
  }

  /* ─── Empty-box visual marker (Webflow-style) ─────────────
     Maakt onzichtbare layout-ruimte zichtbaar met blauw stippellijntje.
     Patroon overgenomen uit `.fs-styleguide_empty-box` van Bell's Comedy Club.
     ────────────────────────────────────────────────────────── */
  .sg-empty-box {
