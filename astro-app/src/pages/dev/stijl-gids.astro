    background: var(--atc-paper);
  }

  /* ─── Swatches ──────────────────────────────────────────── */
  .sg-swatches {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(14rem, 1fr));
    gap: var(--sp-4);
