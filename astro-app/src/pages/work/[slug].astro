---
import Layout from '../../layouts/Layout.astro'
import HeroCaseSection from '../../components/sections/HeroCaseSection.astro'
import PageBuilder from '../../components/PageBuilder.astro'
import CtaRefreinSection from '../../components/sections/CtaRefreinSection.astro'
import {
  getCaseBySlug,
  getAllCaseSlugs,
  getSiteSettings,
} from '../../utils/sanity'

export async function getStaticPaths() {
  const slugs = await getAllCaseSlugs()
  return slugs.map((s: any) => ({ params: { slug: s.slug } }))
}

export const prerender = false // Server-rendered voor Visual Editing draft-mode

const { slug } = Astro.params
const caseDoc = slug ? await getCaseBySlug(slug) : null
const settings = await getSiteSettings()

if (!caseDoc) {
  return Astro.redirect('/404')
}

const seo = caseDoc?.seo ?? {}
const blocks = caseDoc?.content ?? []
const hasExplicitCtaRefrein = blocks.some((b: any) => b._type === 'ctaRefreinBlock')
---

<Layout
  seo={seo}
  title={caseDoc?.title ?? undefined}
  description={caseDoc?.subtitle ?? undefined}
  siteName={settings?.siteName}
  ogImage={seo?.ogImageUrl ?? settings?.defaultSeo?.ogImageUrl}
  noindex={caseDoc?.layer === 'in-flight' && caseDoc?.ndaStatus === true}
>
  <HeroCaseSection case={caseDoc} />

  <PageBuilder blocks={blocks} />

  {/* Auto-append CTA-refrein als editor 'm niet zelf heeft geplaatst */}
  {!hasExplicitCtaRefrein && (
    <CtaRefreinSection pageKey="case-detail" tone="claude" />
  )}
</Layout>
