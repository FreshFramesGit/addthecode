---
import Layout from "../layouts/Layout.astro";
import Section from "../components/layout/Section.astro";
import RichText from "../components/content/RichText.astro";
import CmsLink from "../components/content/CmsLink.astro";
import { getThankYouPage } from "../utils/sanity";

const page = await getThankYouPage();

const heading = page?.heading ?? "Bedankt — bericht ontvangen";
const body = page?.body;
const ctaLabel = page?.ctaLabel ?? "Terug naar home";
const ctaLink = page?.ctaLink ?? "/";
const seo = page?.seo;
---

<Layout title={heading} seo={seo} noindex={true}>
  <Section>
    <div style="text-align: center; min-height: 60vh; display: flex; flex-direction: column; justify-content: center;">
      <h1>{heading}</h1>
      {body && <RichText value={body} />}
      <div style="margin-top: 2rem;">
        <CmsLink link={ctaLink} class="button">{ctaLabel}</CmsLink>
      </div>
    </div>
  </Section>
</Layout>
