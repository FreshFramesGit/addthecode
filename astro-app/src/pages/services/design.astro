---
import Layout from '../../layouts/Layout.astro'
import PageBuilder from '../../components/PageBuilder.astro'
import JsonLd from '../../components/seo/JsonLd.astro'
import { getServiceDesignPage, getSiteSettings } from '../../utils/sanity'

const page = await getServiceDesignPage(Astro.cookies)
const settings = await getSiteSettings(Astro.cookies)

const seo = page?.seo ?? {}
const blocks = page?.content ?? []
const heroBlock = blocks.find((block: any) => block._type === 'heroStandardBlock')
---

<Layout
  seo={seo}
  siteName={settings?.siteName}
  ogImage={seo?.ogImageUrl ?? settings?.defaultSeo?.ogImageUrl}
>
  <Fragment slot="head">
    <JsonLd
      type="Service"
      data={{
        name: heroBlock?.heading ?? 'Design — Add the Code',
        description:
          heroBlock?.subheading ??
          seo?.description ??
          settings?.siteDescription,
        serviceType: 'Design',
        areaServed: 'NL',
      }}
    />
  </Fragment>

  <PageBuilder blocks={blocks} />
</Layout>
