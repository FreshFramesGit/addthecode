---
import { ViewTransitions } from "astro:transitions";
import { perspectiveCookieName } from "@sanity/preview-url-secret/constants";
import Seo from "../components/seo/Seo.astro";
import Nav from "../components/layout/Nav.astro";
import Footer from "../components/layout/Footer.astro";
import SanityVisualEditing from "../components/SanityVisualEditing";
import DisableDraftMode from "../components/DisableDraftMode";
import CookieConsent from "../components/CookieConsent.astro";
import { getSiteSettings } from "../utils/sanity";
import { getBaseUrl } from "../utils/site-url";
import "../styles/global.css";

// GTM container ID — env-driven, leeg = geen tracking. Alleen voor Add the Code.
const gtmId = import.meta.env.PUBLIC_GTM_CONTAINER_ID || "";
const gtmEnabled = /^GTM-[A-Z0-9]+$/i.test(gtmId);

type SeoProps = {
  title?: string | null;
  description?: string | null;
  canonical?: string | null;
  ogImage?: string | null;
  noindex?: boolean | null;
  siteName?: string | null;
  defaultTitle?: string | null;
  defaultDescription?: string | null;
  baseUrl?: string | null;
};

interface Props extends SeoProps {
  lang?: string;
  seo?: SeoProps;
  hideNav?: boolean;
  hideFooter?: boolean;
}

// Fetch siteSettings for defaults — cached per request by Sanity client.
// Geef Astro.cookies door zodat we tijdens Visual Editing draft-content
// in nav/footer zien (bv. siteName-changes).
const settings = await getSiteSettings(Astro.cookies);

const {
  title,
  description,
  canonical,
  ogImage,
  noindex,
  siteName = settings?.siteName ?? "My Site",
  defaultTitle = settings?.defaultSeo?.title ?? siteName,
  defaultDescription = settings?.defaultSeo?.description ?? undefined,
  baseUrl = getBaseUrl(settings, Astro.url.origin),
  lang = settings?.languageCode ?? "nl",
  seo: seoInput = {},
  hideNav = false,
  hideFooter = false,
} = Astro.props as Props;

const seo = seoInput ?? {};

const seoProps: SeoProps = {
  ...seo,
  title: title ?? seo.title,
  description: description ?? seo.description,
  canonical: canonical ?? seo.canonical,
  ogImage: ogImage ?? seo.ogImage ?? settings?.defaultSeo?.ogImageUrl,
  noindex: noindex ?? seo.noindex,
  siteName,
  defaultTitle,
  defaultDescription,
  baseUrl,
};

/**
 * Draft-mode-gate is per-request via cookie (Sanity best-practice).
 *
 * - Geen cookie → published content, geen overlays, geen stega
 * - Cookie aanwezig → draft + click-to-edit overlays + perspective sync
 *
 * De cookie wordt gezet door /api/draft-mode/enable (door Studio's
 * Presentation Tool aangeroepen) en gewist door /api/draft-mode/disable
 * (de floating button onderin).
 */
const draftMode = Astro.cookies.has(perspectiveCookieName);
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="shortcut icon" href={settings?.faviconUrl ?? "/images/favicon.jpg"} type="image/x-icon" />
    <link rel="apple-touch-icon" href={settings?.webclipUrl ?? "/images/webclip.jpg"} />

    {/* Font preloads — display + body voor eerste paint. Mono lazy. */}
    <link
      rel="preload"
      href="/fonts/FKDisplay-Regular.woff2"
      as="font"
      type="font/woff2"
      crossorigin="anonymous"
    />
    <link
      rel="preload"
      href="/fonts/SuisseIntl-Regular.woff2"
      as="font"
      type="font/woff2"
      crossorigin="anonymous"
    />

    {/* Google Search Console verification — alleen renderen als ID gezet is */}
    {settings?.googleSiteVerificationId && (
      <meta name="google-site-verification" content={settings.googleSiteVerificationId} />
    )}

    <ViewTransitions />
    <Seo {...seoProps} />
    <slot name="head" />

    {/*
      ─── Google Tag Manager + Consent Mode v2 ──────────────────
      Volgens https://developers.google.com/tag-platform/security/guides/consent
      en GDPR/AVG (NL):
       1. Consent Mode init met alle storage 'denied' VÓÓR GTM laadt
       2. GTM laadt direct, maar tags die respect_consent honoreren wachten
       3. CookieConsent component (onderaan body) doet `consent update` na accept
      Geen GTM = geen Consent Mode init nodig (geen tracking actief).
    */}
    {gtmEnabled && (
      <>
        <script is:inline>
          // Single source of truth voor gtag: globaal op window zodat
          // CookieConsent + andere components 'm kunnen aanroepen.
          // KRITIEK: gebruikt `arguments` (Arguments-pseudo-array) i.p.v.
          // rest-params Array — GTM's gtag-listener herkent alleen het
          // Arguments-pattern voor consent update calls.
          window.dataLayer = window.dataLayer || [];
          window.gtag = function gtag(){ window.dataLayer.push(arguments); };
          // Default: alles denied tot bezoeker akkoord geeft
          gtag('consent', 'default', {
            ad_storage: 'denied',
            analytics_storage: 'denied',
            ad_user_data: 'denied',
            ad_personalization: 'denied',
            functionality_storage: 'granted',
            security_storage: 'granted',
            wait_for_update: 500,
          });
          // Region-override: voor NL/EU zijn we standaard streng. Buiten EU
          // mogen analytics_storage default 'granted', maar dat kunnen we
          // later afstellen als we internationaal lanceren.
        </script>
        <script is:inline define:vars={{ gtmId }}>
          (function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
          new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
          j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
          'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
          })(window,document,'script','dataLayer',gtmId);
        </script>
      </>
    )}
  </head>
  <body>
    {/* GTM noscript — moet eerste element in <body> zijn voor users met JS uit */}
    {gtmEnabled && (
      <noscript>
        <iframe
          src={`https://www.googletagmanager.com/ns.html?id=${gtmId}`}
          height="0"
          width="0"
          style="display:none;visibility:hidden"
          title="Google Tag Manager"
        />
      </noscript>
    )}

    {!hideNav && <Nav />}
    {/*
      Geen .nav-spacer meer: enterprise .nav is `position: sticky` (niet
      fixed), dus content schuift natuurlijk onder de nav. Spacer was
      nodig bij `position: fixed` — Universal Rule #6 voldaan via sticky.
    */}

    <main class="main-content">
      <slot />
    </main>

    {!hideFooter && <Footer />}

    {/* Cookie consent banner — alleen tonen wanneer GTM aan staat én niet in draft-mode */}
    {gtmEnabled && !draftMode && <CookieConsent />}

    {/* Analytics: sitebreed CTA-click tracking voor primary buttons + nav-CTAs */}
    {gtmEnabled && (
      <script is:inline>
        (function () {
          function getCtaLabel(el) {
            // Clone het element, strip arrow/ring/svg, dan textContent.
            // Werkt voor alle DOM-structuren (span/svg/inline mix).
            const clone = el.cloneNode(true)
            clone.querySelectorAll('.btn__arrow, .tr, svg').forEach(function (n) {
              n.remove()
            })
            return (clone.textContent || '').trim().replace(/\s+/g, ' ')
          }

          function trackCtaClick(e) {
            const target = e.target.closest('a.btn, button.btn')
            if (!target) return
            // Alleen primary + on-dark CTAs tracken — ghost = secondary navigation
            if (
              !target.classList.contains('btn--primary') &&
              !target.classList.contains('btn--on-dark')
            )
              return
            const label = getCtaLabel(target)
            if (!label) return
            window.dataLayer = window.dataLayer || []
            window.dataLayer.push({
              event: 'cta_click',
              cta_label: label,
              cta_location: window.location.pathname,
            })
          }

          document.addEventListener('click', trackCtaClick)
        })()
      </script>
    )}

    {draftMode && (
      <>
        <SanityVisualEditing client:only="react" />
        <DisableDraftMode client:only="react" />
      </>
    )}
  </body>
</html>
