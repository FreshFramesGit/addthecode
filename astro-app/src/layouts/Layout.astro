---
import { ViewTransitions } from "astro:transitions";
import { perspectiveCookieName } from "@sanity/preview-url-secret/constants";
import Seo from "../components/seo/Seo.astro";
import Nav from "../components/layout/Nav.astro";
import Footer from "../components/layout/Footer.astro";
import SanityVisualEditing from "../components/SanityVisualEditing";
import DisableDraftMode from "../components/DisableDraftMode";
import { getSiteSettings } from "../utils/sanity";
import { getBaseUrl } from "../utils/site-url";
import "../styles/global.css";

type SeoProps = {
  title?: string | null;
  description?: string | null;
  canonical?: string | null;
  ogImage?: string | null;
  noindex?: boolean | null;
  siteName?: string | null;
  defaultTitle?: string | null;
  defaultDescription?: string | null;
  baseUrl?: string | null;
};

interface Props extends SeoProps {
  lang?: string;
  seo?: SeoProps;
  hideNav?: boolean;
  hideFooter?: boolean;
}

// Fetch siteSettings for defaults — cached per request by Sanity client.
// Geef Astro.cookies door zodat we tijdens Visual Editing draft-content
// in nav/footer zien (bv. siteName-changes).
const settings = await getSiteSettings(Astro.cookies);

const {
  title,
  description,
  canonical,
  ogImage,
  noindex,
  siteName = settings?.siteName ?? "My Site",
  defaultTitle = settings?.defaultSeo?.title ?? siteName,
  defaultDescription = settings?.defaultSeo?.description ?? undefined,
  baseUrl = getBaseUrl(settings, Astro.url.origin),
  lang = settings?.languageCode ?? "nl",
  seo: seoInput = {},
  hideNav = false,
  hideFooter = false,
} = Astro.props as Props;

const seo = seoInput ?? {};

const seoProps: SeoProps = {
  ...seo,
  title: title ?? seo.title,
  description: description ?? seo.description,
  canonical: canonical ?? seo.canonical,
  ogImage: ogImage ?? seo.ogImage ?? settings?.defaultSeo?.ogImageUrl,
  noindex: noindex ?? seo.noindex,
  siteName,
  defaultTitle,
  defaultDescription,
  baseUrl,
};

/**
 * Draft-mode-gate is per-request via cookie (Sanity best-practice).
 *
 * - Geen cookie → published content, geen overlays, geen stega
 * - Cookie aanwezig → draft + click-to-edit overlays + perspective sync
 *
 * De cookie wordt gezet door /api/draft-mode/enable (door Studio's
 * Presentation Tool aangeroepen) en gewist door /api/draft-mode/disable
 * (de floating button onderin).
 */
const draftMode = Astro.cookies.has(perspectiveCookieName);
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="shortcut icon" href={settings?.faviconUrl ?? "/images/favicon.jpg"} type="image/x-icon" />
    <link rel="apple-touch-icon" href={settings?.webclipUrl ?? "/images/webclip.jpg"} />

    {/* Font preloads — display + body voor eerste paint. Mono lazy. */}
    <link
      rel="preload"
      href="/fonts/FKDisplay-Regular.woff2"
      as="font"
      type="font/woff2"
      crossorigin="anonymous"
    />
    <link
      rel="preload"
      href="/fonts/SuisseIntl-Regular.woff2"
      as="font"
      type="font/woff2"
      crossorigin="anonymous"
    />

    {/* Google Search Console verification — alleen renderen als ID gezet is */}
    {settings?.googleSiteVerificationId && (
      <meta name="google-site-verification" content={settings.googleSiteVerificationId} />
    )}

    <ViewTransitions />
    <Seo {...seoProps} />
    <slot name="head" />

    {/* TODO Phase 4: tracking-keuze door Alex (open: GA4/GTM, Plausible, Vercel-analytics, of niets) */}
  </head>
  <body>
    {!hideNav && <Nav />}
    {/*
      Geen .nav-spacer meer: enterprise .nav is `position: sticky` (niet
      fixed), dus content schuift natuurlijk onder de nav. Spacer was
      nodig bij `position: fixed` — Universal Rule #6 voldaan via sticky.
    */}

    <main class="main-content">
      <slot />
    </main>

    {!hideFooter && <Footer />}

    {draftMode && (
      <>
        <SanityVisualEditing client:only="react" />
        <DisableDraftMode client:only="react" />
      </>
    )}
  </body>
</html>
