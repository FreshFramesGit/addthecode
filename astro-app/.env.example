# ─── Sanity project (required) ───────────────────────────────
PUBLIC_SANITY_STUDIO_PROJECT_ID=your-project-id
PUBLIC_SANITY_STUDIO_DATASET=production
PUBLIC_SANITY_PROJECT_ID=your-project-id
PUBLIC_SANITY_DATASET=production

# ─── Sanity Studio URL (for Visual Editing stega links) ─────
# Lokaal: http://localhost:3333  ·  Productie: https://studio.addthecode.nl
PUBLIC_SANITY_STUDIO_URL=http://localhost:3333

# ─── Site URL (canonical env name) ──────────────────────────
# Use PUBLIC_SITE_URL in Vercel and local .env files.
# Astro's import.meta.env.SITE is derived from astro.config.mjs — do not set SITE manually.
PUBLIC_SITE_URL=http://localhost:4321

# ─── Visual Editing ─────────────────────────────────────────
# Cookie-driven (Sanity best-practice) — geen env-flag meer nodig.
# Studio's Presentation Tool zet de perspective-cookie via /api/draft-mode/enable.
# Floating button onderin de site wist 'em via /api/draft-mode/disable.
# Zie https://www.sanity.io/docs/visual-editing/astro-visual-editing

# ─── Server-side only (NO PUBLIC_ prefix) ───────────────────
# Viewer-role token, sanity.io/manage → API → Tokens.
# REQUIRED voor draft-content fetches tijdens Visual Editing.
SANITY_API_READ_TOKEN=your-viewer-token

# ─── Write token (for form submissions API) ─────────────────
# Create an Editor-role token at sanity.io/manage → API → Tokens
SANITY_API_WRITE_TOKEN=your-editor-token

# ─── Forms + bot protection ─────────────────────────────────
# Cloudflare Turnstile keys. Voor lokale dev: gebruik test-keys
# (always-pass mode):
#   PUBLIC_TURNSTILE_SITE_KEY=1x00000000000000000000AA
#   TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA
# Vóór Phase 4 deploy: vervang met echte keys uit dash.cloudflare.com/turnstile.
PUBLIC_TURNSTILE_SITE_KEY=your-turnstile-site-key
TURNSTILE_SECRET_KEY=your-turnstile-secret-key

# ─── Optional webhook / ESP fanout ──────────────────────────
# Leave empty when Sanity-first inbox storage is enough.
# CONTACT_WEBHOOK_URL=
# NEWSLETTER_WEBHOOK_URL=
